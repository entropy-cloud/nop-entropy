{
  "name": "plan-execution",
  "maxTotalSteps": 30,
  "maxCycleVisits": 10,
  "pingPongWindow": 6,
  "entry": "EXECUTE",

  "markerAliases": {
    "success": "pass",
    "ok": "pass",
    "done": "pass",
    "error": "fail",
    "failed": "fail"
  },

  "steps": {
    "EXECUTE": {
      "type": "agent",
      "promptPath": "prompts/execute.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pass": { "goto": "CLOSURE_SCRIPT_CHECK" },
        "fail": { "retry": "EXECUTE", "maxRetries": 3 }
      },
      "onMaxRetries": { "goto": "CLOSURE_SCRIPT_CHECK" },
      "onError": { "goto": "CLOSURE_SCRIPT_CHECK" }
    },

    "CLOSURE_SCRIPT_CHECK": {
      "type": "script",
      "scriptId": "closure-script-check",
      "transitions": {
        "pass": { "goto": "BUILD_VERIFY" },
        "fail": { "goto": "CLOSURE_AUDIT" }
      }
    },

    "CLOSURE_AUDIT": {
      "type": "agent",
      "promptPath": "prompts/closure-audit.md",
      "maxRetries": 3,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "approved": { "goto": "BUILD_VERIFY" },
        "issues": {
          "retry": "EXECUTE",
          "maxRetries": 3,
          "append": { "template": "\n\n## Closure Audit Feedback\n\nThe plan `{{PLAN_FILE}}` was not properly closed. Re-execute it based on the following feedback:\n\nScript check result: {{SCRIPT_CHECK_RESULT}}\nScript check details: {{SCRIPT_CHECK_DETAILS}}\n\nAudit findings:\n${output}" }
        }
      },
      "onMaxRetries": { "goto": "BUILD_VERIFY" },
      "onError": { "retry": "EXECUTE", "maxRetries": 2 }
    },

    "BUILD_VERIFY": {
      "type": "agent",
      "promptPath": "prompts/build-verify.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pass": { "done": "completed" },
        "fail": { "retry": "EXECUTE", "maxRetries": 3 }
      },
      "onMaxRetries": { "done": "failed" },
      "onError": { "retry": "EXECUTE", "maxRetries": 2 }
    }
  }
}
