{
  "name": "goal-driver",
  "maxTotalSteps": 500,
  "maxCycleVisits": 30,
  "maxValidationRetries": 2,
  "pingPongWindow": 6,
  "entry": "HEALTH_CHECK",

  "validateFlowVars": {
    "PLAN_FILE": { "exists": true }
  },

  "markerAliases": {
    "ok": "pass",
    "healthy": "pass",
    "success": "pass",
    "error": "fail",
    "failed": "fail",
    "incomplete": "pending",
    "done": "complete",
    "has_pending": "pending",
    "has_work": "pending",
    "problems": "issues",
    "findings": "issues",
    "concerns": "issues"
  },

  "steps": {
    "HEALTH_CHECK": {
      "type": "agent",
      "promptPath": "prompts/health-check.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pass": { "goto": "PLAN_ROUTER" },
        "fail": { "retry": "HEALTH_CHECK", "maxRetries": 3 }
      },
      "onMaxRetries": { "done": "failed" },
      "onError": { "retry": "HEALTH_CHECK", "maxRetries": 3 }
    },

    "PLAN_ROUTER": {
      "type": "script",
      "scriptId": "plan-router",
      "transitions": {
        "execute": { "goto": "EXECUTE_PLAN" },
        "roadmap": { "goto": "ROADMAP_CHECK" }
      }
    },

    "ROADMAP_CHECK": {
      "type": "agent",
      "promptPath": "prompts/roadmap-check.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pending": {
          "goto": "PLAN_DRAFT",
          "append": { "template": "\n\nSelected work item from roadmap check:\n${output}" }
        },
        "complete": { "goto": "DEEP_AUDIT_LOOP" }
      },
      "onError": { "goto": "DEEP_AUDIT_LOOP" }
    },

    "PLAN_DRAFT": {
      "type": "agent",
      "promptPath": "prompts/plan-draft.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "created": { "goto": "PLAN_AUDIT" },
        "none": { "goto": "DEEP_AUDIT_LOOP" }
      },
      "onError": { "goto": "DEEP_AUDIT_LOOP" }
    },

    "PLAN_AUDIT": {
      "type": "agent",
      "promptPath": "prompts/plan-audit.md",
      "maxRetries": 3,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "approved": { "goto": "EXECUTE_PLAN" },
        "issues": {
          "retry": "PLAN_DRAFT",
          "maxRetries": 3,
          "append": { "template": "\n\nPlan review feedback — revise the plan accordingly:\n${output}" }
        }
      },
      "onError": { "retry": "PLAN_DRAFT", "maxRetries": 2 },
      "onMaxRetries": { "goto": "EXECUTE_PLAN" }
    },

    "EXECUTE_PLAN": {
      "type": "subflow",
      "flow": "plan-execution",
      "flowArgs": { "PLAN_FILE": "{{PLAN_FILE}}" },
      "transitions": {
        "pass": { "goto": "PLAN_ROUTER" },
        "failed": { "goto": "PLAN_ROUTER" }
      },
      "onError": { "goto": "PLAN_ROUTER" }
    },

    "DEEP_AUDIT_LOOP": {
      "type": "subflow",
      "flow": "deep-audit-loop",
      "transitions": {
        "clean": { "goto": "ADVERSARIAL" },
        "failed": { "goto": "PLAN_ROUTER" }
      },
      "onError": { "goto": "PLAN_ROUTER" }
    },

    "ADVERSARIAL": {
      "type": "agent",
      "promptPath": "prompts/adversarial-review.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "clean": { "done": "completed" },
        "issues": { "goto": "PLAN_DRAFT" }
      },
      "onError": { "done": "completed" }
    }
  }
}
