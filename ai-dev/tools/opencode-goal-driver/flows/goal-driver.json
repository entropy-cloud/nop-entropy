{
  "name": "goal-driver",
  "maxTotalSteps": 500,
  "maxCycleVisits": 30,
  "maxValidationRetries": 2,
  "pingPongWindow": 6,
  "entry": "HEALTH_CHECK",

  "validateFlowVars": {
    "PLAN_FILE": { "exists": true }
  },

  "markerAliases": {
    "ok": "pass",
    "healthy": "pass",
    "success": "pass",
    "error": "fail",
    "failed": "fail",
    "incomplete": "pending",
    "done": "complete",
    "has_pending": "pending",
    "has_work": "pending",
    "problems": "issues",
    "findings": "issues",
    "concerns": "issues",
    "none": "created",
    "revised": "created"
  },

  "steps": {
    "HEALTH_CHECK": {
      "type": "agent",
      "promptPath": "prompts/health-check.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pass": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" },
        "fail": { "retry": "HEALTH_CHECK", "maxRetries": 3 }
      },
      "onMaxRetries": { "done": "failed" },
      "onError": { "retry": "HEALTH_CHECK", "maxRetries": 3 }
    },

    "EXECUTE_ALL_ACTIVE_PLANS": {
      "type": "group",
      "maxRounds": 1,
      "steps": {
        "SCAN_PLANS": {
          "type": "script",
          "scriptId": "scan-active-plans",
          "transitions": {
            "ok": { "goto": "EXECUTE_EACH_PLAN" },
            "empty": { "exit": "done" }
          }
        },
        "EXECUTE_EACH_PLAN": {
          "type": "subflow",
          "flow": "plan-execution",
          "forEach": "items",
          "flowArgs": { "PLAN_FILE": "{{forEachItem}}" },
          "transitions": {
            "all_complete": { "exit": "done" },
            "some_failed": { "exit": "done" },
            "all_failed": { "exit": "done" }
          },
          "onError": { "exit": "done" }
        }
      },
      "transitions": {
        "done": { "goto": "ROADMAP_CHECK" },
        "fail": { "goto": "ROADMAP_CHECK" }
      },
      "onError": { "goto": "ROADMAP_CHECK" }
    },

    "ROADMAP_CHECK": {
      "type": "agent",
      "promptPath": "prompts/roadmap-check.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pending": {
          "goto": "PLAN_DRAFT",
          "append": { "template": "\n\nSelected work item from roadmap check:\n${output}" }
        },
        "complete": { "goto": "DEEP_AUDIT_LOOP" }
      },
      "onError": { "goto": "DEEP_AUDIT_LOOP" }
    },

    "PLAN_DRAFT": {
      "type": "agent",
      "promptPath": "prompts/plan-draft.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "created": { "goto": "PLAN_AUDIT" }
      },
      "onError": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" }
    },

    "PLAN_AUDIT": {
      "type": "agent",
      "promptPath": "prompts/plan-audit.md",
      "maxRetries": 3,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "approved": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" },
        "issues": {
          "retry": "PLAN_DRAFT",
          "maxRetries": 3,
          "append": { "template": "\n\n## REVISION REQUEST\n\nYour previous plan at `{{PLAN_FILE}}` did not pass audit. Revise it **in-place** (edit the existing file, do NOT create a new plan) based on the feedback below, then output `created`:\n\n${output}" }
        }
      },
      "onError": { "retry": "PLAN_DRAFT", "maxRetries": 2 },
      "onMaxRetries": { "goto": "EXECUTE_ALL_ACTIVE_PLANS", "append": { "template": "\n\n⚠️ This plan did not pass audit after max retries. Proceeding in degraded mode." } }
    },

    "DEEP_AUDIT_LOOP": {
      "type": "subflow",
      "flow": "deep-audit-loop",
      "transitions": {
        "clean": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" },
        "failed": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" }
      },
      "onError": { "goto": "EXECUTE_ALL_ACTIVE_PLANS" }
    }
  }
}
