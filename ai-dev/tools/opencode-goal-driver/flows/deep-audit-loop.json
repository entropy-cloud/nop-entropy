{
  "name": "deep-audit-loop",
  "maxTotalSteps": 40,
  "maxCycleVisits": 15,
  "pingPongWindow": 6,
  "entry": "DEEP_AUDIT",

  "markerAliases": {
    "ok": "clean",
    "pass": "clean",
    "success": "clean",
    "done": "clean",
    "error": "fail",
    "failed": "fail",
    "problems": "issues",
    "findings": "issues",
    "concerns": "issues",
    "none": "created",
    "revised": "created"
  },

  "steps": {
    "DEEP_AUDIT": {
      "type": "agent",
      "promptPath": "prompts/deep-audit.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "clean": {
          "goto": "ADVERSARIAL",
          "append": { "template": "\n\n## Deep Audit Result\n\nDeep audit found no issues:\n${output}" }
        },
        "issues": {
          "goto": "ADVERSARIAL",
          "append": { "template": "\n\n## Deep Audit Result\n\nDeep audit found issues:\n${output}" }
        }
      },
      "onError": { "done": "completed" }
    },

    "ADVERSARIAL": {
      "type": "agent",
      "promptPath": "prompts/adversarial-review.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "clean": { "done": "completed" },
        "issues": {
          "goto": "DRAFT_PLANS",
          "append": { "template": "\n\n## Combined Audit + Adversarial Findings\n\n${output}" }
        }
      },
      "onError": { "done": "completed" }
    },

    "DRAFT_PLANS": {
      "type": "agent",
      "promptPath": "prompts/draft-plans.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "created": { "done": "completed" }
      },
      "onError": { "done": "completed" }
    }
  }
}
