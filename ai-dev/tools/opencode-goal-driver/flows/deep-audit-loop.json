{
  "name": "deep-audit-loop",
  "maxTotalSteps": 40,
  "maxCycleVisits": 15,
  "pingPongWindow": 6,
  "maxAuditRounds": 3,
  "entry": "DEEP_AUDIT",

  "markerAliases": {
    "ok": "clean",
    "pass": "clean",
    "success": "clean",
    "done": "clean",
    "error": "fail",
    "failed": "fail",
    "problems": "issues",
    "findings": "issues",
    "concerns": "issues"
  },

  "steps": {
    "DEEP_AUDIT": {
      "type": "agent",
      "promptPath": "prompts/deep-audit.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "clean": { "done": "completed" },
        "issues": { "goto": "DRAFT_PLAN" }
      },
      "onError": { "done": "completed" }
    },

    "DRAFT_PLAN": {
      "type": "agent",
      "promptPath": "prompts/plan-draft.md",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "created": { "goto": "AUDIT_PLAN" },
        "revised": { "goto": "AUDIT_PLAN" },
        "none": { "goto": "DEEP_AUDIT" }
      },
      "onError": { "goto": "DEEP_AUDIT" }
    },

    "AUDIT_PLAN": {
      "type": "agent",
      "promptPath": "prompts/plan-audit.md",
      "maxRetries": 3,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "approved": { "goto": "EXECUTE_PLAN" },
        "issues": {
          "retry": "DRAFT_PLAN",
          "maxRetries": 3,
          "append": { "template": "\n\n## REVISION REQUEST\n\nYour previous plan at `{{PLAN_FILE}}` did not pass audit. Revise it **in-place** (edit the existing file, do NOT create a new plan) based on the feedback below, then output `revised`:\n\n${output}" }
        }
      },
      "onError": { "retry": "DRAFT_PLAN", "maxRetries": 2 },
      "onMaxRetries": { "goto": "EXECUTE_PLAN", "append": { "template": "\n\n⚠️ This plan did not pass audit after max retries. Proceeding in degraded mode." } }
    },

    "EXECUTE_PLAN": {
      "type": "subflow",
      "flow": "plan-execution",
      "flowArgs": { "PLAN_FILE": "{{PLAN_FILE}}" },
      "transitions": {
        "pass": { "goto": "DEEP_AUDIT" },
        "failed": { "goto": "DEEP_AUDIT" }
      },
      "onError": { "goto": "DEEP_AUDIT" }
    }
  }
}
