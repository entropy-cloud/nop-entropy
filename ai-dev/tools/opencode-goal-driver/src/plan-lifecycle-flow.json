{
  "name": "plan-lifecycle",
  "maxTotalSteps": 60,
  "maxCycleVisits": 10,
  "entry": "CHECK_STATUS",

  "markerAliases": {
    "已批准": "approved",
    "有问题": "issues",
    "完成": "complete",
    "已完成": "complete",
    "未完成": "incomplete",
    "成功": "success",
    "失败": "failed"
  },

  "steps": {
    "CHECK_STATUS": {
      "type": "script",
      "run": "readPlanStatus",
      "transitions": {
        "draft": { "goto": "AUDIT" },
        "active": { "goto": "AUDIT" },
        "reviewed": { "goto": "EXECUTE" },
        "completed": { "done": "completed" }
      }
    },

    "AUDIT": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/plan-audit.md",
      "resultTag": "AUDIT_RESULT",
      "maxRetries": 3,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "approved": { "goto": "SET_REVIEWED" },
        "issues": {
          "retry": "AUDIT",
          "maxRetries": 3,
          "append": { "template": "\n\nPlan audit feedback:\n${output}" }
        }
      },
      "onError": { "retry": "AUDIT", "maxRetries": 2 },
      "onMaxRetries": { "goto": "SET_REVIEWED" }
    },

    "SET_REVIEWED": {
      "type": "script",
      "run": "setPlanStatus",
      "scriptArgs": { "status": "reviewed" },
      "transitions": {
        "ok": { "goto": "EXECUTE" },
        "error": { "goto": "EXECUTE" }
      }
    },

    "EXECUTE": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/execute-plan.md",
      "resultTag": "EXECUTE_RESULT",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "success": { "goto": "CLOSURE" },
        "failed": { "goto": "CLOSURE" }
      },
      "onError": { "goto": "CLOSURE" }
    },

    "CLOSURE": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/closure-audit-v2.md",
      "resultTag": "CLOSURE_RESULT",
      "maxRetries": 5,
      "onUnknownMaxRetries": 2,
      "transitions": {
        "complete": { "goto": "SET_COMPLETED" },
        "incomplete": {
          "retry": "EXECUTE",
          "maxRetries": 5,
          "append": { "extract": "REMAINING", "template": "\n\nItems still pending:\n${output}" }
        }
      },
      "onError": {
        "retry": "EXECUTE",
        "maxRetries": 3,
        "append": { "template": "\n\nClosure audit subprocess was killed. Please re-check Exit Criteria." }
      },
      "onMaxRetries": { "goto": "SET_COMPLETED" }
    },

    "SET_COMPLETED": {
      "type": "script",
      "run": "setPlanStatus",
      "scriptArgs": { "status": "completed" },
      "transitions": {
        "ok": { "goto": "COMMIT" },
        "error": { "goto": "COMMIT" }
      }
    },

    "COMMIT": {
      "type": "script",
      "run": "gitCommit",
      "scriptArgs": { "message": "feat({module}): complete plan execution" },
      "transitions": {
        "committed": { "goto": "UPDATE_ROADMAP" },
        "nothing": { "goto": "UPDATE_ROADMAP" },
        "error": { "goto": "COMMIT_FIX" }
      }
    },

    "COMMIT_FIX": {
      "type": "agent",
      "prompt": "Git commit failed for module {module}. Error: {commitError}\n\nFix the issue (e.g. resolve merge conflicts, fix lint errors, remove secrets) and commit using nop-git-master skill. Output <COMMIT_RESULT>fixed</COMMIT_RESULT> or <COMMIT_RESULT>skipped</COMMIT_RESULT>.",
      "resultTag": "COMMIT_RESULT",
      "onUnknownMaxRetries": 1,
      "transitions": {
        "fixed": { "goto": "UPDATE_ROADMAP" },
        "skipped": { "goto": "UPDATE_ROADMAP" }
      },
      "onError": { "goto": "UPDATE_ROADMAP" }
    },

    "UPDATE_ROADMAP": {
      "type": "script",
      "run": "updateRoadmap",
      "transitions": {
        "updated": { "done": "completed" },
        "skipped": { "done": "completed" },
        "error": { "done": "completed" }
      }
    }
  }
}
