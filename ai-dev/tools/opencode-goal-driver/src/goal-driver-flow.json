{
  "name": "goal-driver",
  "maxTotalSteps": 120,
  "maxCycleVisits": 20,
  "entry": "FIX_TESTS",

  "markerAliases": {
    "已创建": "created",
    "已批准": "approved",
    "有问题": "issues",
    "无": "none",
    "完成": "complete",
    "已完成": "complete",
    "未完成": "incomplete",
    "成功": "success",
    "失败": "failed",
    "修复": "fixed",
    "无错误": "no_errors",
    "通过": "approved",
    "待处理": "pending",
    "干净": "clean",
    "需要": "needed",
    "不需要": "not_needed"
  },

  "steps": {
    "FIX_TESTS": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/fix-tests.md",
      "resultTag": "TEST_RESULT",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "fixed": { "goto": "FIX_TESTS_COMMIT" },
        "no_errors": { "goto": "CHECK_PENDING_PLANS" },
        "failed": { "goto": "FIX_TESTS_RECOVERY" }
      },
      "onError": { "retry": "FIX_TESTS", "maxRetries": 2 }
    },

    "FIX_TESTS_COMMIT": {
      "type": "script",
      "run": "gitCommit",
      "scriptArgs": { "message": "fix({module}): fix unit test errors" },
      "transitions": {
        "committed": { "goto": "CHECK_PENDING_PLANS" },
        "nothing": { "goto": "CHECK_PENDING_PLANS" },
        "error": { "goto": "FIX_TESTS_COMMIT_FIX" }
      }
    },

    "FIX_TESTS_COMMIT_FIX": {
      "type": "agent",
      "prompt": "Git commit failed after fixing tests for module {module}. Error: {commitError}\n\nFix the issue (resolve conflicts, fix lint errors, remove secrets) and commit using nop-git-master skill. Output <COMMIT_RESULT>fixed</COMMIT_RESULT> or <COMMIT_RESULT>skipped</COMMIT_RESULT>.",
      "resultTag": "COMMIT_RESULT",
      "onUnknownMaxRetries": 1,
      "transitions": {
        "fixed": { "goto": "CHECK_PENDING_PLANS" },
        "skipped": { "goto": "CHECK_PENDING_PLANS" }
      },
      "onError": { "goto": "CHECK_PENDING_PLANS" }
    },

    "FIX_TESTS_RECOVERY": {
      "type": "agent",
      "prompt": "Test fix for module {module} failed. Re-analyze test failures with a more conservative strategy. If test expectations genuinely need updating, update them with a clear explanation. Run ./mvnw test -pl {module} -am -T 1C to verify. Output <TEST_RESULT>fixed</TEST_RESULT> or <TEST_RESULT>failed</TEST_RESULT>.",
      "resultTag": "TEST_RESULT",
      "onUnknownMaxRetries": 1,
      "transitions": {
        "fixed": { "goto": "CHECK_PENDING_PLANS" },
        "failed": { "done": "tests_failed" }
      },
      "onError": { "done": "tests_failed" }
    },

    "CHECK_PENDING_PLANS": {
      "type": "script",
      "run": "checkPendingPlans",
      "transitions": {
        "has_plans": { "goto": "PROCESS_PENDING_PLANS" },
        "no_plans": { "goto": "ROADMAP_CHECK" }
      }
    },

    "PROCESS_PENDING_PLANS": {
      "type": "subflow",
      "flow": "plan-lifecycle",
      "forEach": "activePlanFiles",
      "transitions": {
        "all_complete": { "goto": "ROADMAP_CHECK" },
        "some_failed": { "goto": "ROADMAP_CHECK" },
        "all_failed": { "goto": "ROADMAP_CHECK" }
      }
    },

    "ROADMAP_CHECK": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/roadmap-check.md",
      "resultTag": "ROADMAP_RESULT",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "pending": { "goto": "PLAN_DRAFT", "append": true },
        "complete": { "goto": "NEEDS_DEEP_AUDIT" }
      },
      "onError": { "goto": "NEEDS_DEEP_AUDIT" }
    },

    "PLAN_DRAFT": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/plan-draft.md",
      "resultTag": "PLAN_RESULT",
      "onUnknownMaxRetries": 2,
      "extractVars": {
        "planFile": "Plan file:\\s*(ai-dev/plans/\\S+\\.md)"
      },
      "transitions": {
        "created": { "goto": "PLAN_EXECUTE" },
        "none": { "goto": "NEEDS_DEEP_AUDIT" }
      },
      "onError": { "goto": "NEEDS_DEEP_AUDIT" }
    },

    "PLAN_EXECUTE": {
      "type": "subflow",
      "flow": "plan-lifecycle",
      "flowArgs": { "planFile": "{steps.PLAN_DRAFT.vars.planFile}" },
      "transitions": {
        "complete": { "goto": "NEEDS_DEEP_AUDIT" },
        "failed": { "goto": "NEEDS_DEEP_AUDIT" }
      }
    },

    "NEEDS_DEEP_AUDIT": {
      "type": "agent",
      "promptFile": "ai-dev/tools/opencode-goal-driver/prompts/needs-deep-audit.md",
      "resultTag": "DEEP_AUDIT_NEEDED",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "needed": { "goto": "DEEP_AUDIT" },
        "not_needed": { "done": "completed" }
      },
      "onError": { "done": "completed" }
    },

    "DEEP_AUDIT": {
      "type": "agent",
      "prompt": "Run a multi-dimensional deep audit on module {module}. Read and follow ai-dev/skills/deep-audit-prompts.md. Write results to ai-dev/audits/{DATE}-deep-audit-{module}/. Output <AUDIT_RESULT>clean</AUDIT_RESULT> or <AUDIT_RESULT>issues</AUDIT_RESULT>.",
      "resultTag": "AUDIT_RESULT",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "issues": { "goto": "ADVERSARIAL" },
        "clean": { "goto": "ADVERSARIAL" }
      },
      "onError": { "goto": "ADVERSARIAL" }
    },

    "ADVERSARIAL": {
      "type": "agent",
      "prompt": "Run an adversarial review on module {module}. Read and follow ai-dev/skills/open-ended-adversarial-review-prompt.md. Write results to ai-dev/audits/{DATE}-adversarial-review-{module}/. Output <ADVERSARIAL_RESULT>clean</ADVERSARIAL_RESULT> or <ADVERSARIAL_RESULT>issues</ADVERSARIAL_RESULT>.",
      "resultTag": "ADVERSARIAL_RESULT",
      "onUnknownMaxRetries": 2,
      "transitions": {
        "issues": { "goto": "AUDIT_PLAN_DRAFT" },
        "clean": { "done": "completed" }
      },
      "onError": { "done": "completed" }
    },

    "AUDIT_PLAN_DRAFT": {
      "type": "agent",
      "prompt": "Draft a remediation plan for module {module} based on audit findings. Audit results: {steps.ADVERSARIAL.text}\n\nRead ai-dev/plans/00-plan-authoring-and-execution-guide.md for plan format. Write the plan file to ai-dev/plans/. Output <PLAN_RESULT>created</PLAN_RESULT> or <PLAN_RESULT>none</PLAN_RESULT>.\n\nWhen creating a plan, include a line: Plan file: ai-dev/plans/YYYY-MM-DD-NNN-slug.md",
      "resultTag": "PLAN_RESULT",
      "onUnknownMaxRetries": 2,
      "extractVars": {
        "planFile": "Plan file:\\s*(ai-dev/plans/\\S+\\.md)"
      },
      "transitions": {
        "created": { "goto": "AUDIT_PLAN_EXECUTE" },
        "none": { "goto": "FIX_TESTS" }
      },
      "onError": { "goto": "FIX_TESTS" }
    },

    "AUDIT_PLAN_EXECUTE": {
      "type": "subflow",
      "flow": "plan-lifecycle",
      "flowArgs": { "planFile": "{steps.AUDIT_PLAN_DRAFT.vars.planFile}" },
      "transitions": {
        "complete": { "goto": "FIX_TESTS" },
        "failed": { "goto": "FIX_TESTS" }
      }
    }
  }
}
