<?xml version="1.0" encoding="UTF-8" ?>

<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd"
       xmlns:ioc="ioc">

    <!-- Migration Engine -->
    <bean id="nopMigrationEngine" class="io.nop.db.migration.core.MigrationEngine">
    </bean>

    <!-- Migration History Manager -->
    <bean id="nopMigrationHistoryManager" class="io.nop.db.migration.core.MigrationHistoryManager">
    </bean>

    <!-- Migration File Scanner -->
    <bean id="nopMigrationFileScanner" class="io.nop.db.migration.core.MigrationFileScanner">
    </bean>

    <!-- Migration Executor -->
    <bean id="nopMigrationExecutor" class="io.nop.db.migration.core.MigrationExecutor">
        <property name="executors">
            <ioc:collect-beans as-map="true"
                               name-prefix="nopChangeExecutor_"
                               by-type="io.nop.db.migration.executor.IChangeExecutor"/>
        </property>
    </bean>

    <!-- Change Executors -->
    <bean id="nopChangeExecutor_sql" class="io.nop.db.migration.executor.SqlExecutor"/>
    <bean id="nopChangeExecutor_createTable" class="io.nop.db.migration.executor.CreateTableExecutor"/>
    <bean id="nopChangeExecutor_dropTable" class="io.nop.db.migration.executor.DropTableExecutor"/>
    <bean id="nopChangeExecutor_renameTable" class="io.nop.db.migration.executor.RenameTableExecutor"/>
    <bean id="nopChangeExecutor_addColumn" class="io.nop.db.migration.executor.AddColumnExecutor"/>
    <bean id="nopChangeExecutor_dropColumn" class="io.nop.db.migration.executor.DropColumnExecutor"/>
    <bean id="nopChangeExecutor_alterColumn" class="io.nop.db.migration.executor.AlterColumnExecutor"/>
    <bean id="nopChangeExecutor_createIndex" class="io.nop.db.migration.executor.CreateIndexExecutor"/>
    <bean id="nopChangeExecutor_dropIndex" class="io.nop.db.migration.executor.DropIndexExecutor"/>
    <bean id="nopChangeExecutor_createView" class="io.nop.db.migration.executor.CreateViewExecutor"/>
    <bean id="nopChangeExecutor_dropView" class="io.nop.db.migration.executor.DropViewExecutor"/>
    <bean id="nopChangeExecutor_insertData" class="io.nop.db.migration.executor.InsertDataExecutor"/>
    <bean id="nopChangeExecutor_updateData" class="io.nop.db.migration.executor.UpdateDataExecutor"/>
    <bean id="nopChangeExecutor_deleteData" class="io.nop.db.migration.executor.DeleteDataExecutor"/>
    <bean id="nopChangeExecutor_customChange" class="io.nop.db.migration.executor.CustomChangeExecutor"/>
</beans>
