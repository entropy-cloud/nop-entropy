<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopAiModel" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/ai/model/NopAiModel/NopAiModel.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--供应商-->
                <col id="provider" mandatory="true" sortable="true"/>

                <!--模型名称-->
                <col id="modelName" mandatory="true" sortable="true"/>

                <!--API地址-->
                <col id="baseUrl" sortable="true"/>

                <!--API密钥-->
                <col id="apiKey" sortable="true"/>

                <!--数据版本-->
                <col id="version" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--输入单价-->
                <col id="inputPricePer1m" ui:number="true" sortable="true"/>

                <!--输出单价-->
                <col id="outputPricePer1m" ui:number="true" sortable="true"/>

                <!--推理单价-->
                <col id="reasoningPricePer1m" ui:number="true" sortable="true"/>

                <!--缓存读单价-->
                <col id="cacheReadPricePer1m" ui:number="true" sortable="true"/>

                <!--缓存写单价-->
                <col id="cacheWritePricePer1m" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currency" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-AI模型" i18n-en:title="View AI Model">
            <layout>
 provider[供应商] modelName[模型名称]
 baseUrl[API地址] apiKey[API密钥]
 version[数据版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] inputPricePer1m[输入单价]
 outputPricePer1m[输出单价] reasoningPricePer1m[推理单价]
 cacheReadPricePer1m[缓存读单价] cacheWritePricePer1m[缓存写单价]
 currency[币种] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-AI模型" i18n-en:title="Add AI Model" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-AI模型" i18n-en:title="Edit AI Model">
            <layout>
 provider[供应商] modelName[模型名称]
 baseUrl[API地址] apiKey[API密钥]
 version[数据版本] inputPricePer1m[输入单价]
 outputPricePer1m[输出单价] reasoningPricePer1m[推理单价]
 cacheReadPricePer1m[缓存读单价] cacheWritePricePer1m[缓存写单价]
 currency[币种] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-AI模型" i18n-en:title="Update AI Model"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopAiModel__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopAiModel__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopAiModel__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopAiModel__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopAiModel__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopAiModel__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopAiModel__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopAiModel__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopAiModel__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopAiModel__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>