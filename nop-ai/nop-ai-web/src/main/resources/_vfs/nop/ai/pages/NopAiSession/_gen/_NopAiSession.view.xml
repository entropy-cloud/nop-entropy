<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopAiSession" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/ai/model/NopAiSession/NopAiSession.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--项目ID-->
                <col id="projectId" mandatory="true" sortable="true"/>

                <!--父会话ID-->
                <col id="parentSessionId" sortable="true"/>

                <!--Agent名称-->
                <col id="agentName" mandatory="true" sortable="true"/>

                <!--模型供应商-->
                <col id="modelProvider" sortable="true"/>

                <!--模型名称-->
                <col id="modelName" sortable="true"/>

                <!--会话Slug-->
                <col id="slug" sortable="true"/>

                <!--会话标题-->
                <col id="title" sortable="true"/>

                <!--工作目录-->
                <col id="directory" sortable="true"/>

                <!--会话状态-->
                <col id="status" mandatory="true" ui:number="true" sortable="true"/>

                <!--费用-->
                <col id="cost" ui:number="true" sortable="true"/>

                <!--输入Token数-->
                <col id="tokensInput" ui:number="true" sortable="true"/>

                <!--输出Token数-->
                <col id="tokensOutput" ui:number="true" sortable="true"/>

                <!--推理Token数-->
                <col id="tokensReasoning" ui:number="true" sortable="true"/>

                <!--缓存读取Token数-->
                <col id="tokensCacheRead" ui:number="true" sortable="true"/>

                <!--缓存写入Token数-->
                <col id="tokensCacheWrite" ui:number="true" sortable="true"/>

                <!--总字节数-->
                <col id="totalBytes" ui:number="true" sortable="true"/>

                <!--上下文元数据-->
                <col id="contextMetadata" sortable="true"/>

                <!--元数据-->
                <col id="metadata" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--压缩时间-->
                <col id="compactedAt" sortable="true"/>

                <!--归档时间-->
                <col id="archivedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-Agent会话" i18n-en:title="View Agent Session">
            <layout>
 projectId[项目ID] parentSessionId[父会话ID]
 agentName[Agent名称] modelProvider[模型供应商]
 modelName[模型名称] slug[会话Slug]
 title[会话标题] directory[工作目录]
 status[会话状态] cost[费用]
 tokensInput[输入Token数] tokensOutput[输出Token数]
 tokensReasoning[推理Token数] tokensCacheRead[缓存读取Token数]
 tokensCacheWrite[缓存写入Token数] totalBytes[总字节数]
 contextMetadata[上下文元数据] metadata[元数据]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 compactedAt[压缩时间] archivedAt[归档时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-Agent会话" i18n-en:title="Add Agent Session" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-Agent会话" i18n-en:title="Edit Agent Session">
            <layout>
 projectId[项目ID] parentSessionId[父会话ID]
 agentName[Agent名称] modelProvider[模型供应商]
 modelName[模型名称] slug[会话Slug]
 title[会话标题] directory[工作目录]
 status[会话状态] cost[费用]
 tokensInput[输入Token数] tokensOutput[输出Token数]
 tokensReasoning[推理Token数] tokensCacheRead[缓存读取Token数]
 tokensCacheWrite[缓存写入Token数] totalBytes[总字节数]
 contextMetadata[上下文元数据] metadata[元数据]
 compactedAt[压缩时间] archivedAt[归档时间]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-Agent会话" i18n-en:title="Update Agent Session"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopAiSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopAiSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopAiSession__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopAiSession__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopAiSession__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopAiSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopAiSession__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopAiSession__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopAiSession__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopAiSession__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>