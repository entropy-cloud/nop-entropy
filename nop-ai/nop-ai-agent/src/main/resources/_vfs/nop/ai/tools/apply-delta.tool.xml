<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      name="apply-delta">

    <schema>
        <apply-delta id="!int" explanation="!string"
                     path="!string" deltaPath="string" dryRun="boolean">
            <deltaContent>xml</deltaContent>
        </apply-delta>
    </schema>

    <description><![CDATA[对指定DSL文件应用Nop平台Delta合并算法并更新该文件。Delta内容（通过deltaContent或deltaPath提供）应为一个XML根节点，表示要合并的修改部分。
    工具自动将该内容作为扩展与path对应的基础文件合并，合并机制基于Nop的x:override规则（如replace/merge/remove等），无需在delta中显式声明x:extends。
支持两种delta输入方式（二选一）：
- deltaPath：已有delta文件的虚拟路径，该文件必须包含一个XML根节点。
- deltaContent：直接提供XML格式的delta内容，必须包含有且仅有一个XML根节点（作为<deltaContent>的直接子元素）。
若同时提供，优先使用deltaContent。
dryRun=true时仅返回合并结果预览，不实际写入文件；dryRun=false时将合并结果写回path指定的文件（覆盖原内容），成功后仅返回确认信息。]]></description>

    <example>
        <!-- 示例1：通过delta内容预览合并（dryRun） -->
        <call-tools>
            <apply-delta id="1" explanation="Preview adding mobile field"
                         path="/nop/auth/app.orm.xml" dryRun="true">
                <deltaContent>
                    <orm>
                        <entities>
                            <entity name="io.nop.auth.dao.entity.NopAuthUser">
                                <columns>
                                    <column name="mobile" stdDomain="string" displayName="手机号" length="20"/>
                                </columns>
                            </entity>
                        </entities>
                    </orm>
                </deltaContent>
            </apply-delta>
        </call-tools>
        <call-tools-response>
            <tool-result id="1" status="success"/>
        </call-tools-response>

        <!-- 示例2：通过已有delta文件实际更新文件（dryRun=false，不返回合并内容） -->
        <call-tools>
            <apply-delta id="2" explanation="Apply beans delta and save"
                         path="/nop/auth/auth-service.beans.xml"
                         deltaPath="/_delta/default/nop/auth/auth-service.beans.xml"/>
        </call-tools>
        <call-tools-response>
            <tool-result id="2" status="success">
                <output><![CDATA[Delta applied successfully. File updated: /nop/auth/auth-service.beans.xml]]></output>
            </tool-result>
        </call-tools-response>
    </example>

</tool>