<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      name="copy-file">

    <schema>
        <copy-file id="!int" explanation="!string" timeoutMs="int"
                   source="!full-path" target="!full-path" recursive="boolean" overwrite="boolean"/>
    </schema>

    <description><![CDATA[复制文件或目录。支持：
- source：源路径
- target：目标路径
- recursive：复制目录时是否递归（默认 false）
- overwrite：是否覆盖已存在的目标（默认 false）
操作成功时返回确认信息。]]></description>

    <example>
        <!-- 示例：复制文件 -->
        <call-tools>
            <copy-file id="1" explanation="Copy config file" timeoutMs="4000"
                       source="/etc/app/config.ini" target="/backup/config.ini" overwrite="false"/>
        </call-tools>
        <call-tools-response>
            <tool-result id="1" status="success">
                <output><![CDATA[File copied successfully from /etc/app/config.ini to /backup/config.ini]]></output>
            </tool-result>
        </call-tools-response>

        <!-- 示例：递归复制目录 -->
        <call-tools>
            <copy-file id="2" explanation="Backup project folder" timeoutMs="10000"
                       source="/projects/myapp" target="/backups/myapp" recursive="true" overwrite="true"/>
        </call-tools>
        <call-tools-response>
            <tool-result id="2" status="success">
                <output><![CDATA[Directory copied successfully from /projects/myapp to /backups/myapp]]></output>
            </tool-result>
        </call-tools-response>
    </example>

</tool>