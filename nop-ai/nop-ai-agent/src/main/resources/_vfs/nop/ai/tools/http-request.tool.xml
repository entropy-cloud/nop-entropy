<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      name="http-request">

    <schema>
        <http-request id="!int" explanation="!string" timeoutMs="int"
                      url="!string" method="enum:GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS"
                      followRedirects="boolean" maxRedirects="int">
            <!-- 请求头 -->
            <headers>
                <header name="!string" value="string"/>*
            </headers>

            <!-- 请求体（对GET/HEAD忽略） -->
            <body>string</body>

            <!-- 查询参数（自动URL编码） -->
            <params>
                <param name="!string" value="string"/>*
            </params>

            <!-- 认证配置（可选） -->
            <auth type="enum:none|basic|bearer|digest">
                <username>string</username>
                <password>string</password>
                <token>string</token>
            </auth>
        </http-request>
    </schema>

    <description><![CDATA[执行HTTP请求，返回结构化响应。支持多种HTTP方法、自定义头、请求体、查询参数和认证方式。
返回结果为JSON格式，包含：
- status: HTTP状态码
- headers: 响应头对象
- body: 响应体（JSON自动解析为对象，否则为字符串）
- redirected: 是否发生重定向
- url: 最终URL（跟随重定向后）

适用于API调用、数据获取、服务集成等场景。]]></description>

    <examples>
        <example index="1">
            <!-- 示例1：GET请求获取数据 -->
            <call-tools>
                <http-request id="1" explanation="Fetch weather data" timeoutMs="5000"
                              url="https://api.open-meteo.com/v1/forecast" method="GET">
                    <params>
                        <param name="latitude" value="52.52"/>
                        <param name="longitude" value="13.41"/>
                        <param name="current_weather" value="true"/>
                    </params>
                    <headers>
                        <header name="Accept" value="application/json"/>
                    </headers>
                </http-request>
            </call-tools>
            <call-tools-response>
                <tool-result id="1" status="success">
                    <output><![CDATA[{
      "status": 200,
      "headers": {
        "content-type": "application/json",
        "date": "Wed, 13 Mar 2026 10:00:00 GMT"
      },
      "body": {
        "latitude": 52.52,
        "longitude": 13.41,
        "current_weather": {
          "temperature": 12.3,
          "windspeed": 15.5,
          "weathercode": 1
        }
      },
      "redirected": false,
      "url": "https://api.open-meteo.com/v1/forecast?latitude=52.52&longitude=13.41&current_weather=true"
    }]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="2">
            <!-- 示例2：POST请求创建资源 -->
            <call-tools>
                <http-request id="2" explanation="Create new todo item" timeoutMs="3000"
                              url="https://jsonplaceholder.typicode.com/todos" method="POST">
                    <headers>
                        <header name="Content-Type" value="application/json"/>
                        <header name="Accept" value="application/json"/>
                    </headers>
                    <body><![CDATA[{
      "title": "Learn MCP",
      "completed": false,
      "userId": 1
    }]]></body>
                    <auth type="bearer">
                        <token>eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...</token>
                    </auth>
                </http-request>
            </call-tools>
            <call-tools-response>
                <tool-result id="2" status="success">
                    <output><![CDATA[{
      "status": 201,
      "statusText": "Created",
      "headers": {
        "content-type": "application/json",
        "location": "/todos/201"
      },
      "body": {
        "id": 201,
        "title": "Learn MCP",
        "completed": false,
        "userId": 1
      },
      "redirected": false,
      "url": "https://jsonplaceholder.typicode.com/todos"
    }]]></output>
                </tool-result>
            </call-tools-response>
        </example>
    </examples>

</tool>