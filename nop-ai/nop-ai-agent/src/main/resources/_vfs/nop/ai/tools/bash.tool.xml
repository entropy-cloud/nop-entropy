<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:xdef="/nop/schema/xdef.xdef"
      name="bash">

    <schema>
        <bash id="!int" explanation="!string" timeoutMs="int" workingDir="full-path">
            <command>!string</command>
            <env name="!string" value="!string" xdef:unique-attr="name"/>
        </bash>
    </schema>

    <description><![CDATA[执行 Bash 命令。支持：
- workingDir：工作目录（可选，默认当前目录）
- env：环境变量列表（可选），每个包含 name 和 value
- command：要执行的命令内容（支持多行）
成功时返回 stdout 作为 output，exitCode 为 0；失败时（exitCode ≠ 0）将 stderr 放入 error，status 设为 failure，并提供具体退出码。
适用于系统操作、脚本执行等场景。]]></description>

    <examples>
        <example index="1">
            <!-- 示例1：执行简单命令，成功返回 -->
            <call-tools>
                <bash id="1" explanation="List files" timeoutMs="5000" workingDir="/tmp">
                    <command><![CDATA[ls -la]]></command>
                    <env name="LANG" value="en_US.UTF-8"/>
                </bash>
            </call-tools>
            <call-tools-response>
                <tool-result id="1" status="success" exitCode="0">
                    <output><![CDATA[
    total 8
    drwxr-xr-x  2 user user 4096 Mar 12 10:00 .
    drwxr-xr-x 24 user user 4096 Mar 12 09:00 ..
    ]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="2">
            <!-- 示例2：执行失败命令，返回错误信息及退出码 -->
            <call-tools>
                <bash id="2" explanation="Run invalid command" timeoutMs="3000">
                    <command><![CDATA[cat /nonexistent/file]]></command>
                </bash>
            </call-tools>
            <call-tools-response>
                <tool-result id="2" status="failure" exitCode="1">
                    <error><![CDATA[cat: /nonexistent/file: No such file or directory]]></error>
                </tool-result>
            </call-tools-response>
        </example>
    </examples>

</tool>