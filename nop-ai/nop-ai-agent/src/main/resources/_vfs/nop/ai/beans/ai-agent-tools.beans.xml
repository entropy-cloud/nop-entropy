<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns:x="/nop/schema/xdsl.xdef"
       xmlns:ioc="urn: nop-ioc:1.0">

    <!-- Engine-aware tool executors that require access to IAgentEngine / IAgentMessenger.
         These beans are auto-collected by the existing <ioc:collect-beans by-type="...IToolExecutor"/>
         in nop-ai-toolkit's ai-tools-defaults.beans.xml. -->

    <bean id="ai-agent-tools:call-agent" class="io.nop.ai.agent.tool.CallAgentExecutor"/>
    <bean id="ai-agent-tools:send-message" class="io.nop.ai.agent.tool.SendMessageExecutor"/>

    <!-- Working-memory tool executors (plan 189). Same auto-collect path
         via <ioc:collect-beans by-type="...IToolExecutor"/>. Each tool
         reads the per-session IAiMemoryStore from AgentToolExecuteContext. -->
    <bean id="ai-agent-tools:read-memory" class="io.nop.ai.agent.tool.ReadMemoryExecutor"/>
    <bean id="ai-agent-tools:write-memory" class="io.nop.ai.agent.tool.WriteMemoryExecutor"/>
    <bean id="ai-agent-tools:search-memory" class="io.nop.ai.agent.tool.SearchMemoryExecutor"/>

</beans>
