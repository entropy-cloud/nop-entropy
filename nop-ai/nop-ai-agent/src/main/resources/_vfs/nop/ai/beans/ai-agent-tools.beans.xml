<?xml version="1.0" encoding="UTF-8"?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns:ioc="ioc">

    <!-- Engine-aware tool executors that require access to IAgentEngine / IAgentMessenger.
         These beans are auto-collected by the existing <ioc:collect-beans by-type="...IToolExecutor"/>
         in nop-ai-toolkit's ai-tools-defaults.beans.xml. -->

    <bean id="ai-agent-tools:call-agent" class="io.nop.ai.agent.tool.CallAgentExecutor"/>
    <bean id="ai-agent-tools:send-message" class="io.nop.ai.agent.tool.SendMessageExecutor"/>

    <!-- Working-memory tool executors (plan 189). Same auto-collect path
         via <ioc:collect-beans by-type="...IToolExecutor"/>. Each tool
         reads the per-session IAiMemoryStore from AgentToolExecuteContext. -->
    <bean id="ai-agent-tools:read-memory" class="io.nop.ai.agent.tool.ReadMemoryExecutor"/>
    <bean id="ai-agent-tools:write-memory" class="io.nop.ai.agent.tool.WriteMemoryExecutor"/>
    <bean id="ai-agent-tools:search-memory" class="io.nop.ai.agent.tool.SearchMemoryExecutor"/>

    <!-- Team-aware tool executors (plan 225 / L4-8-team-tools). Each tool
         reads the ITeamManager / ITeamTaskStore from AgentToolExecuteContext.
         NoOp defaults (NoOpTeamManager + NoOpTeamTaskStore) cause honest
         "not enabled" reports, not silent success. Same auto-collect path. -->
    <bean id="ai-agent-tools:team-send-message" class="io.nop.ai.agent.tool.TeamSendMessageExecutor"/>
    <bean id="ai-agent-tools:team-status" class="io.nop.ai.agent.tool.TeamStatusExecutor"/>
    <bean id="ai-agent-tools:team-task-create" class="io.nop.ai.agent.tool.TeamTaskCreateExecutor"/>
    <bean id="ai-agent-tools:team-task-update" class="io.nop.ai.agent.tool.TeamTaskUpdateExecutor"/>

    <!-- Team-execute-flow tool executor (plan 239 / L4-team-execute-flow-llm-tool).
         The top Layer 4 LLM entry point that drives TeamTaskFlowOrchestrator
         to execute the caller's team task DAG via a tool call. Resolves the
         caller's team from the session (no teamId parameter), enforces the
         WRITE ACL, then per-invocation constructs the orchestrator with the
         wire-at-consumer member spawner (NoOp shipped default → zero
         regression; functional spawner → run-time auto-spawn of unbound
         members). Same auto-collect path. -->
    <bean id="ai-agent-tools:team-execute-flow" class="io.nop.ai.agent.tool.TeamExecuteFlowExecutor"/>

</beans>
