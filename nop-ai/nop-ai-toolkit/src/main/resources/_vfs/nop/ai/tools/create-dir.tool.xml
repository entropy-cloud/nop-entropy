<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      name="create-dir">

    <schema>
        <create-dir id="!int" explanation="!string"
                    path="!full-path" createParents="boolean"/>
    </schema>

    <description><![CDATA[创建目录。支持：
- path：要创建的目录路径
- createParents：是否同时创建不存在的父目录（类似 mkdir -p，默认 false）
操作成功时返回确认信息。]]></description>

    <examples>
        <example index="1">
            <call-tools>
                <create-dir id="1" explanation="Create data directory"
                            path="/var/data/app/logs" createParents="true"/>
            </call-tools>
            <call-tools-response>
                <tool-result id="1" status="success">
                    <output><![CDATA[Directory created successfully: /var/data/app/logs]]></output>
                </tool-result>
            </call-tools-response>
        </example>
    </examples>

</tool>