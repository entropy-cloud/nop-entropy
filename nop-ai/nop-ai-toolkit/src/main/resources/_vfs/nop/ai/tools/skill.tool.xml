<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      name="skill">

    <schema>
        <skill id="!int" explanation="!string"
               action="!string" skillName="string"/>
    </schema>

    <description><![CDATA[管理智能体技能。支持以下action：
- list：列出所有可用技能及其详情（无需skillName）
- load：动态加载指定技能到当前agent上下文（需skillName）
适用于技能发现、动态扩展能力等场景。]]></description>

    <examples>
        <example index="1">
            <!-- 示例1：列出所有可用技能 -->
            <call-tools>
                <skill id="1" explanation="List all available skills"
                       action="list"/>
            </call-tools>
            <call-tools-response>
                <tool-result id="1" status="success">
                    <output><![CDATA[<skills>
      <skill name="log-analysis">Analyze log files for errors and patterns</skill>
      <skill name="translator">Translate text between languages</skill>
    </skills>]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="2">
            <!-- 示例2：动态加载技能到当前上下文 -->
            <call-tools>
                <skill id="2" explanation="Load python skill to calculate data statistics"
                       action="load" skillName="python"/>
            </call-tools>
            <call-tools-response>
                <tool-result id="2" status="success">
                    <output><![CDATA[Skill 'python' loaded successfully.]]></output>
                </tool-result>
            </call-tools-response>
        </example>
    </examples>

</tool>