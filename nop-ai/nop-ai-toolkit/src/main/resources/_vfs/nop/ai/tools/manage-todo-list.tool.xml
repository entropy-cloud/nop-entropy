<tool x:schema="/nop/schema/ai/tool/tool.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:xdef="/nop/schema/xdef.xdef"
      name="manage-todo-list">

    <schema>
        <manage-todo-list id="!int" explanation="!string">
            <todos xdef:body-type="list">
                <todo content="!string" status="!enum:pending|in_progress|completed"/>
            </todos>
        </manage-todo-list>
    </schema>

    <description><![CDATA[管理任务待办列表，用于跟踪多步骤任务的执行进度。每次调用传入完整列表，服务端替换式更新。可与其他工具在同次调用中并行执行。

**何时使用**：
- 复杂的多步骤任务（3步以上）
- 用户明确要求使用 todo list 或提供多个任务
- 接收到新指令时，创建任务列表
- 开始一项任务时，标记为 in_progress
- 完成一项任务时，标记为 completed，并添加执行中发现的后续任务

**何时不使用**：
- 单一简单的任务（3步以内）
- 纯对话或信息性任务

**状态说明**：
- pending: 待处理
- in_progress: 正在执行（整个列表中恰好一个）
- completed: 已完成
- 不再需要的任务直接从列表中移除，无需标记

**核心原则**：
1. 同时只能有一个任务处于 in_progress
2. completed 仅在实际完成并验证后标记，不能基于意图提前标记
3. 被阻塞时保持 in_progress，并新增一条 todo 描述阻塞原因
4. 列表顺序即优先级：靠前的项先执行
5. 用户提供的原始命令保持原样

**与 Plan 的关系**：
- Plan 定义"做什么"（战略层，步骤、依赖、完成条件）
- Todo 跟踪"当前在做什么"（战术层，实时进度）
- Todo 是 Plan 的轻量级补充，两者独立维护]]></description>

    <examples>
        <example index="1">
            <call-tools>
                <manage-todo-list id="1" explanation="开始用户注册功能开发，共4步" >
                    <todos>
                        <todo content="实现表单校验" status="in_progress"/>
                        <todo content="创建注册API端点" status="pending"/>
                        <todo content="添加邮件验证流程" status="pending"/>
                        <todo content="编写集成测试" status="pending"/>
                    </todos>
                </manage-todo-list>
            </call-tools>
            <call-tools-response>
                <tool-result id="1" status="success">
                    <output><![CDATA[Updated todo list: 1 in_progress, 3 pending]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="2">
            <call-tools>
                <manage-todo-list id="2" explanation="表单校验已完成，开始API端点开发" >
                    <todos>
                        <todo content="实现表单校验" status="completed"/>
                        <todo content="创建注册API端点" status="in_progress"/>
                        <todo content="添加邮件验证流程" status="pending"/>
                        <todo content="编写集成测试" status="pending"/>
                    </todos>
                </manage-todo-list>
                <bash id="3" explanation="创建API路由文件" timeoutMs="5000">
                    <command><![CDATA[cat src/routes/api.ts]]></command>
                </bash>
            </call-tools>
            <call-tools-response>
                <tool-result id="2" status="success">
                    <output><![CDATA[Updated todo list: 1 completed, 1 in_progress, 2 pending]]></output>
                </tool-result>
                <tool-result id="3" status="success" exitCode="0">
                    <output><![CDATA[export async function POST(req: Request) { ... }]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="3">
            <call-tools>
                <manage-todo-list id="4" explanation="所有任务已完成" >
                    <todos>
                        <todo content="实现表单校验" status="completed"/>
                        <todo content="创建注册API端点" status="completed"/>
                        <todo content="编写集成测试" status="completed"/>
                    </todos>
                </manage-todo-list>
            </call-tools>
            <call-tools-response>
                <tool-result id="4" status="success">
                    <output><![CDATA[All 3 items completed]]></output>
                </tool-result>
            </call-tools-response>
        </example>

        <example index="4">
            <call-tools>
                <manage-todo-list id="5" explanation="API端点开发中遇到数据库连接问题，记录阻塞" >
                    <todos>
                        <todo content="实现表单校验" status="completed"/>
                        <todo content="创建注册API端点" status="in_progress"/>
                        <todo content="修复数据库连接配置（阻塞API端点测试）" status="pending"/>
                        <todo content="添加邮件验证流程" status="pending"/>
                        <todo content="编写集成测试" status="pending"/>
                    </todos>
                </manage-todo-list>
            </call-tools>
            <call-tools-response>
                <tool-result id="5" status="success">
                    <output><![CDATA[Updated todo list: 1 completed, 1 in_progress, 3 pending]]></output>
                </tool-result>
            </call-tools-response>
        </example>
    </examples>

</tool>
