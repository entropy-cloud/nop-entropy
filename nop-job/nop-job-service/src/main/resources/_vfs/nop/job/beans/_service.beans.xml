<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" x:extends="/nop/biz/defaults/service-base.beans.xml"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <bean id="io.nop.job.service.entity.NopJobScheduleBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_NopJobSchedule" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="io.nop.job.biz.INopJobScheduleBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="NopJobSchedule"/>
    </bean>

    <bean id="io.nop.job.service.entity.NopJobFireBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_NopJobFire" class="io.nop.biz.proxy.BizProxyFactoryBean" ioc:type="io.nop.job.biz.INopJobFireBiz"
          ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="NopJobFire"/>
    </bean>

    <bean id="io.nop.job.service.entity.NopJobTaskBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_NopJobTask" class="io.nop.biz.proxy.BizProxyFactoryBean" ioc:type="io.nop.job.biz.INopJobTaskBiz"
          ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="NopJobTask"/>
    </bean>
</beans>