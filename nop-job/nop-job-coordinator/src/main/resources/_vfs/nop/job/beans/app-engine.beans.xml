<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd" xmlns:ioc="ioc">

    <import resource="_engine.beans.xml"/>

    <bean id="jobPartitionResolver" class="io.nop.job.coordinator.engine.JobPartitionResolver"/>

    <bean id="io.nop.job.api.retry.IJobRetryBridge"
          class="io.nop.job.coordinator.retry.NoOpJobRetryBridge"/>

    <bean id="io.nop.job.api.alarm.IJobAlarmHandler"
          class="io.nop.job.coordinator.alarm.LoggingJobAlarmHandler"/>

    <bean id="io.nop.job.coordinator.engine.IJobPlannerScanner"
          class="io.nop.job.coordinator.engine.JobPlannerScannerImpl">
        <property name="plannerMetrics">
            <bean class="io.nop.job.coordinator.metrics.JobPlannerMetricsImpl"/>
        </property>
        <property name="partitionResolver" ref="jobPartitionResolver"/>
    </bean>

    <bean id="nopJobTaskBuilder_default" class="io.nop.job.coordinator.engine.DefaultJobTaskBuilder"/>
    <bean id="nopJobTaskBuilder_rpcBroadcast" class="io.nop.job.coordinator.engine.RpcBroadcastTaskBuilder"/>
    <bean id="nopJobTaskBuilder_broadcast" class="io.nop.job.coordinator.engine.RpcBroadcastTaskBuilder"/>
    <bean id="nopJobTaskBuilder_partition" class="io.nop.job.coordinator.engine.PartitionTaskBuilder"/>

    <bean id="io.nop.job.coordinator.engine.IJobDispatcherScanner"
          class="io.nop.job.coordinator.engine.JobDispatcherScannerImpl">
        <property name="defaultTaskBuilder" ref="nopJobTaskBuilder_default"/>
        <property name="partitionResolver" ref="jobPartitionResolver"/>
    </bean>

    <bean id="io.nop.job.coordinator.engine.IJobCancelHandler"
          class="io.nop.job.coordinator.engine.DefaultJobCancelHandler"/>

    <bean id="io.nop.job.coordinator.engine.IJobCompletionProcessor"
          class="io.nop.job.coordinator.engine.JobCompletionProcessorImpl">
        <property name="partitionResolver" ref="jobPartitionResolver"/>
        <property name="retryBridge" ref="io.nop.job.api.retry.IJobRetryBridge"/>
        <property name="alarmHandler" ref="io.nop.job.api.alarm.IJobAlarmHandler"/>
    </bean>

    <bean id="io.nop.job.coordinator.engine.IJobTimeoutChecker"
          class="io.nop.job.coordinator.engine.JobTimeoutCheckerImpl">
        <property name="partitionResolver" ref="jobPartitionResolver"/>
        <property name="alarmHandler" ref="io.nop.job.api.alarm.IJobAlarmHandler"/>
    </bean>

    <bean id="io.nop.job.coordinator.engine.JobCoordinator"
          class="io.nop.job.coordinator.engine.JobCoordinator"/>
</beans>
