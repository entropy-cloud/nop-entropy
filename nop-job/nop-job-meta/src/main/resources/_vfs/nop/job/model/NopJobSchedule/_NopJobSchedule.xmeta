      xmlns:orm="orm">

    <entityName>io.nop.job.dao.entity.NopJobSchedule</entityName>

    <primaryKey>jobScheduleId</primaryKey>

    <displayProp>displayName</displayProp>

    <x:gen-extends>
        <meta-gen:DefaultMetaGenExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
