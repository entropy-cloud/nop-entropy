    <x:post-extends>
        <meta-gen:DefaultMetaPostExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
    </x:post-extends>

    <keys>
        <key name="UK_NOP_JOB_SCHEDULE_NS_GROUP_NAME" props="namespaceId,groupId,jobName"/>
    </keys>

    <props>
        <prop name="jobScheduleId" displayName="调度ID" propId="1" i18n-en:displayName="Job Schedule Id" tagSet="seq"
