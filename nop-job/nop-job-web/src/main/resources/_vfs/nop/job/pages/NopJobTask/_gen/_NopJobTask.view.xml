<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopJobTask" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/job/model/NopJobTask/NopJobTask.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--任务ID-->
                <col id="jobTaskId" mandatory="true" sortable="true"/>

                <!--批次ID-->
                <col id="jobFireId" mandatory="true" sortable="true"/>

                <!--任务序号-->
                <col id="taskNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--任务状态-->
                <col id="taskStatus" mandatory="true" ui:number="true" sortable="true"/>

                <!--执行节点ID-->
                <col id="workerInstanceId" sortable="true"/>

                <!--执行节点地址-->
                <col id="workerAddress" sortable="true"/>

                <!--投递参数-->
                <col id="taskPayload" sortable="true"/>

                <!--开始时间-->
                <col id="startTime" sortable="true"/>

                <!--结束时间-->
                <col id="endTime" sortable="true"/>

                <!--执行时长(毫秒)-->
                <col id="durationMs" ui:number="true" sortable="true"/>

                <!--执行结果-->
                <col id="resultPayload" sortable="true"/>

                <!--错误码-->
                <col id="errorCode" sortable="true"/>

                <!--错误消息-->
                <col id="errorMessage" sortable="true"/>

                <!--分区索引-->
                <col id="partitionIndex" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--执行进度-->
                <col id="progress" ui:number="true" sortable="true"/>

                <!--进度消息-->
                <col id="progressMessage" sortable="true"/>

                <!--目标节点地址-->
                <col id="targetHost" sortable="true"/>

                <!--分片索引-->
                <col id="shardingIndex" ui:number="true" sortable="true"/>

                <!--总分片数-->
                <col id="shardingTotal" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-执行任务" i18n-en:title="View Job Task">
            <layout>
 jobTaskId[任务ID] jobFireId[批次ID]
 taskNo[任务序号] taskStatus[任务状态]
 workerInstanceId[执行节点ID] workerAddress[执行节点地址]
 taskPayload[投递参数] startTime[开始时间]
 endTime[结束时间] durationMs[执行时长(毫秒)]
 resultPayload[执行结果] errorCode[错误码]
 errorMessage[错误消息] partitionIndex[分区索引]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] progress[执行进度]
 progressMessage[进度消息] targetHost[目标节点地址]
 shardingIndex[分片索引] shardingTotal[总分片数]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-执行任务" i18n-en:title="Add Job Task" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-执行任务" i18n-en:title="Edit Job Task">
            <layout>
 jobTaskId[任务ID] jobFireId[批次ID]
 taskNo[任务序号] taskPayload[投递参数]
 partitionIndex[分区索引] remark[备注]
 progress[执行进度] progressMessage[进度消息]
 targetHost[目标节点地址] shardingIndex[分片索引]
 shardingTotal[总分片数] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-执行任务" i18n-en:title="Update Job Task"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopJobTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopJobTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopJobTask__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopJobTask__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopJobTask__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopJobTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopJobTask__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopJobTask__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopJobTask__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopJobTask__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>