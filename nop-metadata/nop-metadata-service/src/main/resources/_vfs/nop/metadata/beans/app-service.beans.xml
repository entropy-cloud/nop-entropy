<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 外部数据源按需建连服务：callback 式 withConnection / testConnect。
         纯元数据用途，不注册连接池到 ORM querySpace 路由（架构基线 §2.2）。-->
    <bean id="io.nop.metadata.service.connection.MetaDataSourceConnectionProcessor"
          class="io.nop.metadata.service.connection.MetaDataSourceConnectionProcessor" ioc:default="true"/>

    <!-- 数据契约检查器（设计 04 §5.2 D2）：聚合质量结果 + SLA 新鲜度，由 NopMetaDataContractBizModel 注入。
         无状态，IDaoProvider 由 nop-dao 全局提供。-->
    <bean id="io.nop.metadata.service.contract.MetaContractChecker"
          class="io.nop.metadata.service.contract.MetaContractChecker" ioc:default="true"/>

    <!-- 对账本地匹配服务（设计 08 §1.2 D1 + §四 D2）：对 NopMetaReconciliationEntity 候选集做 exact/fuzzy 匹配，
         由 NopMetaReconciliationConfigBizModel 注入（经 ReconciliationExecutor，按 IReconciliationProcessor 接口解析）。
         IDaoProvider 由 nop-dao 全局提供。外部 HTTP 实现未来可作为新 IReconciliationProcessor impl 插入覆盖。-->
    <bean id="io.nop.metadata.service.reconciliation.LocalReconciliationProcessor"
          class="io.nop.metadata.service.reconciliation.LocalReconciliationProcessor" ioc:default="true"/>

    <!-- 元数据变更事件发布 helper（架构基线 §2.8 / 设计 10 / plan 2026-07-17-0228-1，D2 发布机制主路径）：
         由写路径（关键 mutation action + 核心实体 save/delete override）在持久化成功后调用，
         构造一行 NopMetaModelChangedEvent 并 saveEntity 持久化。无状态，IDaoProvider 由 nop-dao 全局提供。-->
    <bean id="io.nop.metadata.service.event.MetaModelChangedEventPublisher"
          class="io.nop.metadata.service.event.MetaModelChangedEventPublisher" ioc:default="true"/>

    <!-- 质量检查点 cron 定时调度器（架构基线 §2.7.3.1 / plan 2026-07-17-1308-1，普通 IoC bean 非 BizModel）。
         启动 scanner 全量注册 ACTIVE 检查点的 cron job + 运行时增量（save/delete override 调用）。
         IJobScheduler 经 @Inject @Nullable 注入：宿主未注册调度器时为 null，scanner 跳过（不抛崩）。
         注意：此 bean 必须放在 app-service.beans.xml（非生成的 _service.beans.xml），否则 codegen 会覆盖。-->
    <bean id="metaQualityCheckpointScheduler"
          class="io.nop.metadata.service.quality.MetaQualityCheckpointScheduler" ioc:default="true"/>
</beans>