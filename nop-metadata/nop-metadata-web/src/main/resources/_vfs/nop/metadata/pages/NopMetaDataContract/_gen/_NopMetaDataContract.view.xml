<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaDataContract" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaDataContract/NopMetaDataContract.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--契约ID-->
                <col id="contractId" mandatory="true" sortable="true"/>

                <!--契约名-->
                <col id="contractName" mandatory="true" sortable="true"/>

                <!--显示名-->
                <col id="displayName" sortable="true"/>

                <!--关联数据表ID-->
                <col id="entityTableId" sortable="true"/>

                <!--契约状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--契约所有者-->
                <col id="ownerUserId" sortable="true"/>

                <!--JSON Schema 定义-->
                <col id="schema" sortable="true"/>

                <!--SLA 定义-->
                <col id="sla" sortable="true"/>

                <!--质量期望-->
                <col id="qualityExpectations" sortable="true"/>

                <!--安全策略-->
                <col id="security" sortable="true"/>

                <!--最新执行结果-->
                <col id="latestResult" sortable="true"/>

                <!--标签集合-->
                <col id="tagSet" sortable="true"/>

                <!--扩展配置-->
                <col id="extConfig" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--审批状态-->
                <col id="approveStatus" sortable="true"/>

                <!--审批人-->
                <col id="approvedBy" sortable="true"/>

                <!--审批时间-->
                <col id="approvedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-数据契约" i18n-en:title="View Meta Data Contract">
            <layout>
 contractId[契约ID] contractName[契约名]
 displayName[显示名] entityTableId[关联数据表ID]
 status[契约状态] ownerUserId[契约所有者]
 schema[JSON Schema 定义] sla[SLA 定义]
 qualityExpectations[质量期望] security[安全策略]
 latestResult[最新执行结果] tagSet[标签集合]
 extConfig[扩展配置] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
 approveStatus[审批状态] approvedBy[审批人]
 approvedAt[审批时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-数据契约" i18n-en:title="Add Meta Data Contract" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-数据契约" i18n-en:title="Edit Meta Data Contract">
            <layout>
 contractId[契约ID] contractName[契约名]
 displayName[显示名] entityTableId[关联数据表ID]
 status[契约状态] ownerUserId[契约所有者]
 schema[JSON Schema 定义] sla[SLA 定义]
 qualityExpectations[质量期望] security[安全策略]
 latestResult[最新执行结果] tagSet[标签集合]
 extConfig[扩展配置] remark[备注]
 approveStatus[审批状态] approvedBy[审批人]
 approvedAt[审批时间] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-数据契约"
              i18n-en:title="Update Meta Data Contract"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaDataContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaDataContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaDataContract__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaDataContract__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaDataContract__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaDataContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaDataContract__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaDataContract__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaDataContract__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaDataContract__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>