<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaEntityRelation" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaEntityRelation/NopMetaEntityRelation.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--关系ID-->
                <col id="relationId" mandatory="true" sortable="true"/>

                <!--实体ID-->
                <col id="metaEntityId" mandatory="true" sortable="true"/>

                <!--是否Delta-->
                <col id="isDelta" mandatory="true" sortable="true"/>

                <!--关系名-->
                <col id="relationName" mandatory="true" sortable="true"/>

                <!--关系类型-->
                <col id="relationType" mandatory="true" sortable="true"/>

                <!--引用实体名-->
                <col id="refEntityName" sortable="true"/>

                <!--引用属性名-->
                <col id="refPropName" sortable="true"/>

                <!--级联删除-->
                <col id="cascadeDelete" sortable="true"/>

                <!--自动级联删除-->
                <col id="autoCascadeDelete" sortable="true"/>

                <!--可查询-->
                <col id="queryable" sortable="true"/>

                <!--内嵌-->
                <col id="embedded" sortable="true"/>

                <!--不生成代码-->
                <col id="notGenCode" sortable="true"/>

                <!--标签集-->
                <col id="tagSet" sortable="true"/>

                <!--关联条件-->
                <col id="joinConditions" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-实体关系" i18n-en:title="View Meta Entity Relation">
            <layout>
 relationId[关系ID] metaEntityId[实体ID]
 isDelta[是否Delta] relationName[关系名]
 relationType[关系类型] refEntityName[引用实体名]
 refPropName[引用属性名] cascadeDelete[级联删除]
 autoCascadeDelete[自动级联删除] queryable[可查询]
 embedded[内嵌] notGenCode[不生成代码]
 tagSet[标签集] joinConditions[关联条件]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-实体关系" i18n-en:title="Add Meta Entity Relation" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-实体关系" i18n-en:title="Edit Meta Entity Relation">
            <layout>
 relationId[关系ID] metaEntityId[实体ID]
 isDelta[是否Delta] relationName[关系名]
 relationType[关系类型] refEntityName[引用实体名]
 refPropName[引用属性名] cascadeDelete[级联删除]
 autoCascadeDelete[自动级联删除] queryable[可查询]
 embedded[内嵌] notGenCode[不生成代码]
 tagSet[标签集] joinConditions[关联条件]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-实体关系"
              i18n-en:title="Update Meta Entity Relation"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaEntityRelation__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaEntityRelation__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaEntityRelation__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaEntityRelation__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaEntityRelation__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaEntityRelation__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaEntityRelation__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaEntityRelation__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaEntityRelation__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaEntityRelation__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>