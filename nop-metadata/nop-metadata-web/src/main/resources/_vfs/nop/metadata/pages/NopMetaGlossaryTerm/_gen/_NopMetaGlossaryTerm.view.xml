<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaGlossaryTerm" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaGlossaryTerm/NopMetaGlossaryTerm.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--术语ID-->
                <col id="glossaryTermId" mandatory="true" sortable="true"/>

                <!--词汇表ID-->
                <col id="glossaryId" mandatory="true" sortable="true"/>

                <!--父术语ID-->
                <col id="parentTermId" sortable="true"/>

                <!--术语名-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--全限定名-->
                <col id="fullyQualifiedName" sortable="true"/>

                <!--显示名-->
                <col id="displayName" sortable="true"/>

                <!--描述-->
                <col id="description" sortable="true"/>

                <!--同义词-->
                <col id="synonyms" sortable="true"/>

                <!--相关术语-->
                <col id="relatedTerms" sortable="true"/>

                <!--引用信息-->
                <col id="references" sortable="true"/>

                <!--概念映射-->
                <col id="conceptMappings" sortable="true"/>

                <!--IRI标识-->
                <col id="iri" sortable="true"/>

                <!--是否互斥-->
                <col id="mutuallyExclusive" sortable="true"/>

                <!--标签-->
                <col id="tags" sortable="true"/>

                <!--扩展配置-->
                <col id="extConfig" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-词汇表术语" i18n-en:title="View Meta Glossary Term">
            <layout>
 glossaryTermId[术语ID] glossaryId[词汇表ID]
 parentTermId[父术语ID] name[术语名]
 fullyQualifiedName[全限定名] displayName[显示名]
 description[描述] synonyms[同义词]
 relatedTerms[相关术语] references[引用信息]
 conceptMappings[概念映射] iri[IRI标识]
 mutuallyExclusive[是否互斥] tags[标签]
 extConfig[扩展配置] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-词汇表术语" i18n-en:title="Add Meta Glossary Term" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-词汇表术语" i18n-en:title="Edit Meta Glossary Term">
            <layout>
 glossaryTermId[术语ID] glossaryId[词汇表ID]
 parentTermId[父术语ID] name[术语名]
 fullyQualifiedName[全限定名] displayName[显示名]
 description[描述] synonyms[同义词]
 relatedTerms[相关术语] references[引用信息]
 conceptMappings[概念映射] iri[IRI标识]
 mutuallyExclusive[是否互斥] tags[标签]
 extConfig[扩展配置] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-词汇表术语"
              i18n-en:title="Update Meta Glossary Term"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaGlossaryTerm__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaGlossaryTerm__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaGlossaryTerm__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaGlossaryTerm__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaGlossaryTerm__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaGlossaryTerm__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaGlossaryTerm__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaGlossaryTerm__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaGlossaryTerm__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaGlossaryTerm__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>