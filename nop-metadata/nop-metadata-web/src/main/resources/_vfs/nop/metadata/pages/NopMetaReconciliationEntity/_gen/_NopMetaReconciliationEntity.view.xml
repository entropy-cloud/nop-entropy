<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaReconciliationEntity" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaReconciliationEntity/NopMetaReconciliationEntity.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--对账实体ID-->
                <col id="reconEntityId" mandatory="true" sortable="true"/>

                <!--实体ID-->
                <col id="entityId" mandatory="true" sortable="true"/>

                <!--实体名-->
                <col id="entityName" mandatory="true" sortable="true"/>

                <!--实体类型-->
                <col id="entityType" sortable="true"/>

                <!--标识符空间-->
                <col id="identifierSpace" sortable="true"/>

                <!--实体属性-->
                <col id="properties" sortable="true"/>

                <!--最后同步时间-->
                <col id="lastSyncedAt" sortable="true"/>

                <!--扩展配置-->
                <col id="extConfig" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-对账实体" i18n-en:title="View Meta Reconciliation Entity">
            <layout>
 reconEntityId[对账实体ID] entityId[实体ID]
 entityName[实体名] entityType[实体类型]
 identifierSpace[标识符空间] properties[实体属性]
 lastSyncedAt[最后同步时间] extConfig[扩展配置]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-对账实体" i18n-en:title="Add Meta Reconciliation Entity" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-对账实体" i18n-en:title="Edit Meta Reconciliation Entity">
            <layout>
 reconEntityId[对账实体ID]
 entityId[实体ID]
 entityName[实体名]
 entityType[实体类型]
 identifierSpace[标识符空间]
 properties[实体属性]
 lastSyncedAt[最后同步时间]
 extConfig[扩展配置]
 remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-对账实体"
              i18n-en:title="Update Meta Reconciliation Entity"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaReconciliationEntity__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaReconciliationEntity__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaReconciliationEntity__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaReconciliationEntity__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaReconciliationEntity__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaReconciliationEntity__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaReconciliationEntity__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaReconciliationEntity__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaReconciliationEntity__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaReconciliationEntity__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>