<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaDataProduct" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaDataProduct/NopMetaDataProduct.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--数据产品ID-->
                <col id="dataProductId" mandatory="true" sortable="true"/>

                <!--所属业务域ID-->
                <col id="businessDomainId" mandatory="true" sortable="true"/>

                <!--产品名-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--显示名-->
                <col id="displayName" sortable="true"/>

                <!--描述-->
                <col id="description" sortable="true"/>

                <!--生命周期阶段-->
                <col id="lifecycleStage" sortable="true"/>

                <!--数据产品类型-->
                <col id="dataProductType" sortable="true"/>

                <!--可见性-->
                <col id="visibility" sortable="true"/>

                <!--投资组合优先级-->
                <col id="portfolioPriority" sortable="true"/>

                <!--SLA定义-->
                <col id="sla" sortable="true"/>

                <!--依赖产品列表-->
                <col id="consumesFrom" sortable="true"/>

                <!--被依赖产品列表-->
                <col id="providesTo" sortable="true"/>

                <!--专家列表-->
                <col id="experts" sortable="true"/>

                <!--关联资产列表-->
                <col id="assets" sortable="true"/>

                <!--数据端口列表-->
                <col id="ports" sortable="true"/>

                <!--扩展配置-->
                <col id="extConfig" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-数据产品" i18n-en:title="View Meta Data Product">
            <layout>
 dataProductId[数据产品ID] businessDomainId[所属业务域ID]
 name[产品名] displayName[显示名]
 description[描述] lifecycleStage[生命周期阶段]
 dataProductType[数据产品类型] visibility[可见性]
 portfolioPriority[投资组合优先级] sla[SLA定义]
 consumesFrom[依赖产品列表] providesTo[被依赖产品列表]
 experts[专家列表] assets[关联资产列表]
 ports[数据端口列表] extConfig[扩展配置]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-数据产品" i18n-en:title="Add Meta Data Product" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-数据产品" i18n-en:title="Edit Meta Data Product">
            <layout>
 dataProductId[数据产品ID] businessDomainId[所属业务域ID]
 name[产品名] displayName[显示名]
 description[描述] lifecycleStage[生命周期阶段]
 dataProductType[数据产品类型] visibility[可见性]
 portfolioPriority[投资组合优先级] sla[SLA定义]
 consumesFrom[依赖产品列表] providesTo[被依赖产品列表]
 experts[专家列表] assets[关联资产列表]
 ports[数据端口列表] extConfig[扩展配置]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-数据产品"
              i18n-en:title="Update Meta Data Product"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaDataProduct__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaDataProduct__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaDataProduct__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaDataProduct__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaDataProduct__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaDataProduct__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaDataProduct__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaDataProduct__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaDataProduct__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaDataProduct__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>