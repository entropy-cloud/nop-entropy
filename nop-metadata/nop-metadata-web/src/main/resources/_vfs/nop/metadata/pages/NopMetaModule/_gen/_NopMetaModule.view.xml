<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopMetaModule" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/metadata/model/NopMetaModule/NopMetaModule.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--模块版本ID-->
                <col id="metaModuleId" mandatory="true" sortable="true"/>

                <!--模块标识-->
                <col id="moduleId" mandatory="true" sortable="true"/>

                <!--模块名-->
                <col id="moduleName" mandatory="true" sortable="true"/>

                <!--显示名-->
                <col id="displayName" sortable="true"/>

                <!--模块版本号-->
                <col id="moduleVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--基线模块版本ID-->
                <col id="baseModuleId" sortable="true"/>

                <!--模块状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--Maven GroupId-->
                <col id="mavenGroupId" sortable="true"/>

                <!--Maven ArtifactId-->
                <col id="mavenArtifactId" sortable="true"/>

                <!--Maven版本-->
                <col id="mavenVersion" sortable="true"/>

                <!--Git仓库路径-->
                <col id="gitRepoPath" sortable="true"/>

                <!--Git分支-->
                <col id="gitBranch" sortable="true"/>

                <!--Git提交-->
                <col id="gitCommitId" sortable="true"/>

                <!--导入时间-->
                <col id="importedAt" sortable="true"/>

                <!--扩展配置-->
                <col id="extConfig" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-元数据模块" i18n-en:title="View Meta Module">
            <layout>
 metaModuleId[模块版本ID] moduleId[模块标识]
 moduleName[模块名] displayName[显示名]
 moduleVersion[模块版本号] baseModuleId[基线模块版本ID]
 status[模块状态] mavenGroupId[Maven GroupId]
 mavenArtifactId[Maven ArtifactId] mavenVersion[Maven版本]
 gitRepoPath[Git仓库路径] gitBranch[Git分支]
 gitCommitId[Git提交] importedAt[导入时间]
 extConfig[扩展配置] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-元数据模块" i18n-en:title="Add Meta Module" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-元数据模块" i18n-en:title="Edit Meta Module">
            <layout>
 metaModuleId[模块版本ID] moduleId[模块标识]
 moduleName[模块名] displayName[显示名]
 moduleVersion[模块版本号] baseModuleId[基线模块版本ID]
 status[模块状态] mavenGroupId[Maven GroupId]
 mavenArtifactId[Maven ArtifactId] mavenVersion[Maven版本]
 gitRepoPath[Git仓库路径] gitBranch[Git分支]
 gitCommitId[Git提交] importedAt[导入时间]
 extConfig[扩展配置] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-元数据模块" i18n-en:title="Update Meta Module"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaModule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopMetaModule__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopMetaModule__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopMetaModule__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopMetaModule__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopMetaModule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopMetaModule__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopMetaModule__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopMetaModule__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopMetaModule__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>