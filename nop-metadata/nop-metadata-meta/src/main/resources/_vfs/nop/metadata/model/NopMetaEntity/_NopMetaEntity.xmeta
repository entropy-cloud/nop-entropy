        <prop name="entityRelations" displayName="实体关系集" i18n-en:displayName="Entity Relations" tagSet="pub,ref-pub"
              ext:kind="to-many" internal="true" ext:joinLeftProp="metaEntityId" ext:joinRightProp="metaEntityId"
              insertable="false" updatable="false" lazy="true">
            <schema>
                <item bizObjName="NopMetaEntityRelation"/>
            </schema>
        </prop>
        <prop name="entityUniqueKeys" displayName="实体唯一键集" i18n-en:displayName="Entity Unique Keys" tagSet="pub,ref-pub"
              ext:kind="to-many" internal="true" ext:joinLeftProp="metaEntityId" ext:joinRightProp="metaEntityId"
