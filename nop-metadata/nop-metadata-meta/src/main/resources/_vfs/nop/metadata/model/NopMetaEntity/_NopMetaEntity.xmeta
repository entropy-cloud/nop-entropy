            <schema type="java.lang.String" precision="200"/>
        </prop>
        <prop name="tableName" displayName="表名" propId="5" i18n-en:displayName="Table Name" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="displayName" displayName="显示名" propId="6" i18n-en:displayName="Display Name" tagSet="disp"
