              insertable="false" updatable="false" mandatory="true" lazy="true">
            <schema bizObjName="NopMetaOrmModel"/>
        </prop>
        <prop name="entityFields" displayName="实体字段集" i18n-en:displayName="Entity Fields" tagSet="pub,ref-pub"
