            <schema type="java.lang.String" precision="200"/>
        </prop>
        <prop name="className" displayName="类名" propId="7" i18n-en:displayName="Class Name" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="300"/>
        </prop>
        <prop name="tagSet" displayName="标签集" propId="8" i18n-en:displayName="Tag Set" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="querySpace" displayName="查询空间" propId="9" i18n-en:displayName="Query Space" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="persistDriver" displayName="持久化驱动" propId="10" i18n-en:displayName="Persist Driver" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="useTenant" displayName="使用租户" propId="11" i18n-en:displayName="Use Tenant" queryable="true"
