            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="delVersionProp" displayName="删除版本属性" propId="21" i18n-en:displayName="Del Version Prop"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="dbCatalog" displayName="数据库目录" propId="22" i18n-en:displayName="DB Catalog" queryable="true"
