<!--
@name agent的唯一名称
-->
<agent x:schema="/nop/schema/xdef.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xdef:name="AgentModel" xdef:bean-package="io.nop.ai.agent.model"
       xmlns:xdef="/nop/schema/xdef.xdef"
       name="!string" tagSet="csv-set"
       workDir="string"
       mode="enum:react,plan,single-turn|react">

    <description>!string</description>

    <!-- 元数据 -->
    <meta>xjson-map</meta>

    <!-- 可选的AI大模型访问参数 -->
    <chatOptions xdef:ref="chat-options.xdef"/>

    <tools>csv-set</tools>

    <availableSkills>csv-set</availableSkills>

    <requiredSkills>csv-set</requiredSkills>

    <permissions xdef:body-type="list" xdef:key-attr="id">
        <permission id="!string" resource="!string" action="!string" xdef:name="AgentPermissionModel"/>
    </permissions>

    <constraints xdef:name="AgentConstraintsModel"
                 maxIterations="int" toolTimeoutSeconds="int" maxParallelTools="int"
                 tokenCompactionThreshold="double-percent"/>

    <!-- per-agent glob path-rules: ordered allow/deny patterns, first-match-wins -->
    <path-rules xdef:body-type="list">
        <rule xdef:name="PathRuleModel" pattern="!string" access="string"/>
    </path-rules>

    <!-- 系统提示词，指导agent的行为模式 -->
    <prompt>prompt-syntax</prompt>

    <hooks xdef:body-type="list" xdef:key-attr="id">
        <on xdef:name="AgentHookModel" id="!string"
            event="!event-pattern-string">xpl-fn:(event, agentRt)=>void
        </on>
    </hooks>

    <!-- Plan 231: declarative team declaration. A lead agent declares its
         team structure here; the engine auto-binds the lead session at the
         three execution entry points (doExecute/resumeSession/restoreSession)
         when a functional ITeamManager is wired. Optional; absent => the
         agent does not lead a team. -->
    <team xdef:name="TeamModel" teamName="!string" description="string"
          leadAgentName="!string" maxParallelMembers="int">
        <members xdef:body-type="list" xdef:key-attr="name">
            <member xdef:name="TeamMemberModel" name="!string" agentModel="!string"
                    role="enum:io.nop.ai.agent.team.MemberRole"/>
        </members>
    </team>

    <!-- Plan 231: declarative team-member reference. A member agent declares
         its team membership here; the engine auto-binds the member session
         when a functional ITeamManager is wired. Optional; absent => the
         agent does not join a team. -->
    <team-member xdef:name="TeamMemberRefModel" teamName="!string" memberName="!string"/>

</agent>