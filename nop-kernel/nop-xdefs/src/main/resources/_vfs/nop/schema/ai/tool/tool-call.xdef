<xdef:unknown-tag x:schema="/nop/schema/xdef.xdef" xmlns:x="/nop/schema/xdsl.xdef"
                  xdef:name="AgentToolCall" xdef:bean-package="io.nop.ai.agent.tool.model"
                  id="!int" explanation="!string" xdef:unknown-attr="string" timeoutMs="int">
    <input>string</input>

    <input-files xdef:body-type="list" xdef:key-attr="path">
        <input-file path="!full-path" description="string" xdef:name="ToolCallInputFile"/>
    </input-files>
</xdef:unknown-tag>