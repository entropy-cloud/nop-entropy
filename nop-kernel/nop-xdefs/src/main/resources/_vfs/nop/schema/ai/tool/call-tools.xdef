<call-tools x:schema="/nop/schema/xdef.xdef" xmlns:x="/nop/schema/xdsl.xdef"
            parallel="boolean=true" maxConcurrency="int"
            xdef:name="AiToolCalls" xdef:bean-package="io.nop.ai.toolkit.model"
            xdef:body-type="list" xdef:key-attr="id">
    <xdef:unknown-tag id="!int" xdef:ref="tool-call.xdef"/>
</call-tools>