<?xml version="1.0" encoding="UTF-8" ?>

<!--
Agent Plan Metamodel Definition

定义AI Agent执行计划的元模型，包含以下特性：
- 阶段驱动（Phase-based）：高层任务分类
- 任务驱动（Task-based）：支持任务递归和并行执行
- 状态跟踪：记录决策、错误、关键问题

-->
<plan x:schema="/nop/schema/xdef.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      xdef:name="AgentPlan" xdef:bean-package="io.nop.ai.agent.plan.model"
      xmlns:xdef="/nop/schema/xdef.xdef"
      currentPhase="string" createdAt="datetime" updatedAt="datetime"
      status="enum:io.nop.ai.agent.model.AgentExecStatus">

    <goal>string</goal>

    <!-- 读取过的有用文件 -->
    <readFiles xdef:body-type="list">
        <readFile path="!full-path" purpose="string" readAt="datetime" xdef:name="AgentPlanReadFileRecord"/>
    </readFiles>

    <!-- 编写的文件 -->
    <writtenFiles xdef:body-type="list">
        <writtenFile path="!full-path" summary="string" lastModified="datetime" xdef:name="AgentPlanWriteFileRecord"/>
    </writtenFiles>

    <!-- 任务阶段列表：用于高层任务分类 -->
    <phases xdef:body-type="list" xdef:key-attr="name">

        <!-- 每个阶段包含多个任务，任务支持递归子任务 -->
        <phase xdef:name="AgentPlanPhase" name="!string"
               status="enum:io.nop.ai.agent.model.AgentExecStatus"
               startedAt="datetime" completedAt="datetime">
            <!-- 阶段描述（大文本） -->
            <description>string</description>

            <!-- 阶段任务列表：支持递归子任务 -->
            <tasks xdef:body-type="list" xdef:key-attr="taskNo">
                <!--
                @dependsOn 指定依赖的任务编号，使用逗号分隔
                -->
                <task taskNo="!string" title="!string" dependsOn="csv-set"
                      status="enum:io.nop.ai.agent.model.AgentExecStatus"
                      startedAt="datetime" completedAt="datetime"
                      xdef:name="AgentPlanTaskModel">

                    <!-- 任务指令（大文本） -->
                    <instructions>!string</instructions>

                    <!-- 任务结果消息（大文本） -->
                    <resultMessage>string</resultMessage>

                    <!-- 递归子任务列表：支持任务分解 -->
                    <subTasks xdef:body-type="list" xdef:key-attr="taskNo">
                        <task xdef:ref="AgentPlanTaskModel" taskNo="!string"/>
                    </subTasks>
                </task>
            </tasks>
        </phase>
    </phases>

    <!-- ========== 关键问题 ========== -->

    <!-- 需要回答的关键问题列表 -->
    <questions xdef:body-type="list" xdef:key-attr="id">
        <question id="!string" xdef:name="AgentPlanQuestion" relatedTaskNo="string" askedAt="datetime"
                  answeredAt="datetime">
            <questionText>string</questionText>
            <answerText>string</answerText>
        </question>
    </questions>

    <!-- ========== 决策记录 ========== -->

    <!-- 任务执行过程中做出的决策记录 -->
    <decisions xdef:body-type="list" xdef:key-attr="id">
        <decision id="!string" madeAt="!datetime" xdef:name="AgentPlanDecision" relatedTaskNo="string">
            <!-- 决策内容（大文本） -->
            <decisionText>string</decisionText>

            <!-- 决策理由（大文本） -->
            <rationale>string</rationale>
        </decision>
    </decisions>

    <!-- ========== 错误记录 ========== -->

    <!-- 任务执行过程中遇到的值得记录的错误记录 -->
    <errors xdef:body-type="list" xdef:key-attr="id">
        <error id="!string" encounteredAt="datetime" attemptNumber="int" resolvedAt="datetime" relatedTaskNo="string"
               xdef:name="AgentPlanError">
            <!-- 错误描述（大文本） -->
            <errorText>string</errorText>
            <!-- 错误解决方案（大文本） -->
            <resolution>string</resolution>
        </error>
    </errors>

    <!-- 任务笔记列表, 用于记录任意扩展信息 -->
    <additionalNotes xdef:body-type="list" xdef:key-attr="id">
        <additionalNote id="!string" xdef:name="AgentPlanNote" relatedTaskNo="string">string</additionalNote>
    </additionalNotes>
</plan>