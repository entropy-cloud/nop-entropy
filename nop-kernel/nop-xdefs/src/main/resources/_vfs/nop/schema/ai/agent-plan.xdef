<?xml version="1.0" encoding="UTF-8" ?>

<!--
Agent Plan Metamodel Definition

定义AI Agent执行计划的元模型，包含以下特性：
- 阶段驱动（Phase-based）：高层任务分类
- 任务驱动（Task-based）：支持任务递归和并行执行
- 状态跟踪：记录决策、错误、关键问题

-->
<plan x:schema="/nop/schema/xdef.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      xdef:name="AgentPlan" xdef:bean-package="io.nop.ai.agent.plan.model"
      xmlns:xdef="/nop/schema/xdef.xdef"
      title="string" currentPhase="string" currentTaskNo="string"
      createdAt="datetime" updatedAt="datetime" reviewedAt="date"
      status="enum:io.nop.ai.agent.model.AgentExecStatus">

    <purpose>string</purpose>

    <goal>string</goal>

    <currentBaseline>string</currentBaseline>

    <sources xdef:body-type="list" xdef:key-attr="id">
        <source id="!string" path="string" xdef:name="AgentPlanSourceRef">string</source>
    </sources>

    <relatedPlans xdef:body-type="list" xdef:key-attr="id">
        <relatedPlan id="!string" path="string" xdef:name="AgentPlanRelatedRef">string</relatedPlan>
    </relatedPlans>

    <successCriteria xdef:body-type="list" xdef:key-attr="id">
        <criterion id="!string" xdef:name="AgentPlanSuccessCriterion">string</criterion>
    </successCriteria>

    <nonGoals xdef:body-type="list" xdef:key-attr="id">
        <nonGoal id="!string" xdef:name="AgentPlanNonGoalItem">string</nonGoal>
    </nonGoals>

    <scope xdef:name="AgentPlanScope">
        <inScope xdef:body-type="list" xdef:key-attr="id">
            <inItem id="!string" xdef:name="AgentPlanScopeItem">string</inItem>
        </inScope>

        <outOfScope xdef:body-type="list" xdef:key-attr="id">
            <outItem id="!string" xdef:ref="AgentPlanScopeItem"/>
        </outOfScope>
    </scope>

    <!-- 读取过的有用文件 -->
    <readFiles xdef:body-type="list">
        <readFile path="!full-path" purpose="string" readAt="datetime" xdef:name="AgentPlanReadFileRecord"/>
    </readFiles>

    <!-- 编写的文件 -->
    <writtenFiles xdef:body-type="list">
        <writtenFile path="!full-path" summary="string" lastModified="datetime" xdef:name="AgentPlanWriteFileRecord"/>
    </writtenFiles>

    <!-- 任务阶段列表：用于高层任务分类 -->
    <phases xdef:body-type="list" xdef:key-attr="name">

        <!-- 每个阶段包含多个任务，任务支持递归子任务 -->
        <phase xdef:name="AgentPlanPhase" name="!string"
               kind="string"
               status="enum:io.nop.ai.agent.model.AgentExecStatus"
               startedAt="datetime" completedAt="datetime">
            <!-- 阶段描述（大文本） -->
            <description>string</description>

            <targets xdef:body-type="list" xdef:key-attr="id">
                <target id="!string" path="string" xdef:name="AgentPlanTarget">string</target>
            </targets>

            <exitCriteria xdef:body-type="list" xdef:key-attr="id">
                <criterion id="!string" completed="boolean" required="boolean" blocking="boolean"
                           xdef:name="AgentPlanCriterion">string</criterion>
            </exitCriteria>

            <!-- 阶段任务列表：支持递归子任务 -->
            <tasks xdef:body-type="list" xdef:key-attr="taskNo">
                <!--
                @dependsOn 指定依赖的任务编号，使用逗号分隔
                -->
                <task taskNo="!string" title="!string" dependsOn="csv-set"
                      status="enum:io.nop.ai.agent.model.AgentExecStatus"
                      startedAt="datetime" completedAt="datetime"
                      xdef:name="AgentPlanTaskModel">

                    <!-- 任务指令（大文本） -->
                    <instructions>!string</instructions>

                    <!-- 任务结果消息（大文本） -->
                    <resultMessage>string</resultMessage>

                    <checks xdef:body-type="list" xdef:key-attr="id">
                        <check id="!string" completed="boolean" required="boolean" blocking="boolean"
                               xdef:ref="AgentPlanCriterion"/>
                    </checks>

                    <!-- 递归子任务列表：支持任务分解 -->
                    <subTasks xdef:body-type="list" xdef:key-attr="taskNo">
                        <task xdef:ref="AgentPlanTaskModel" taskNo="!string"/>
                    </subTasks>
                </task>
            </tasks>
        </phase>
    </phases>

    <!-- ========== 错误记录 ========== -->

    <!-- 任务执行过程中遇到的阻断性或值得追踪的错误记录 -->
    <errors xdef:body-type="list" xdef:key-attr="id">
        <error id="!string" encounteredAt="datetime" attemptNumber="int" resolvedAt="datetime" relatedTaskNo="string"
               blocking="boolean"
               xdef:name="AgentPlanError">
            <errorText>string</errorText>
            <resolution>string</resolution>
        </error>
    </errors>

    <validationChecklist xdef:body-type="list" xdef:key-attr="id">
        <check id="!string" completed="boolean" required="boolean" blocking="boolean"
               xdef:ref="AgentPlanCriterion"/>
    </validationChecklist>

    <closure reviewedBy="string" reviewedAt="datetime" completedAt="datetime"
             xdef:name="AgentPlanClosure">
        <statusNote>string</statusNote>
        <auditEvidence>string</auditEvidence>
        <followUps xdef:body-type="list" xdef:key-attr="id">
            <followUp id="!string" xdef:name="AgentPlanFollowUp">string</followUp>
        </followUps>
    </closure>
</plan>
