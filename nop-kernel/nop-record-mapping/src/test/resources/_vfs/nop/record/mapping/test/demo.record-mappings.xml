<definitions x:schema="/nop/schema/record/record-mappings.xdef" xmlns:x="/nop/schema/xdsl.xdef" x:dump="true">

    <x:post-extends>
        <record-mapping-gen:GenReverseMappings
                xpl:lib="/nop/record/xlib/record-mapping-gen.xlib"/>
    </x:post-extends>

    <mapping name="Type1_to_Type2">
        <fields>
            <field from="field1" mandatory="true" name="base.name1">
                <schema stdDomain="xml-name"/>
            </field>
            <field from="sub.field2" mandatory="true" name="ext.name2">
                <schema/>
            </field>
            <field defaultValue="123" from="sub.field3" mandatory="true" name="ext.name3" type="Integer">
                <schema/>
            </field>
            <field from="field4" name="name4">
                <schema/>
            </field>
            <field from="listB" itemMapping="Item_to_Test" name="listA">
                <schema/>
            </field>
            <field from="mapB" itemMapping="Item_to_Test" name="mapA">
                <schema/>
            </field>
        </fields>
    </mapping>

    <mapping name="PatternFieldTest">
        <patternFields>
            <patternField id="user_age_pattern" fromPattern="user_age" to="age"/>
            <patternField id="user_name_pattern" fromPattern="user_{name}" to="name"/>
            <patternField id="item_code_pattern" fromPattern="item_{code}" to="code"/>
            <patternField id="data_field_pattern" fromPattern="data_{field}" to="${field}"/>
            <patternField id="ignore_pattern" fromPattern="temp_*" ignore="true"/>
            <patternField id="default_pattern" fromPattern="*" to="anyField"/>
        </patternFields>
    </mapping>
    
    <!-- Test for to expression evaluation with variable interpolation -->
    <mapping name="PatternFieldTestWithToExpression">
        <patternFields>
            <patternField id="user_prop_pattern" fromPattern="user.{prop}" to="${prop}"/>
        </patternFields>
    </mapping>
    
    <!-- Test for nested object mapping -->
    <mapping name="PatternFieldTestWithNested">
        <patternFields>
            <patternField id="nested_pattern" fromPattern="{field}" to="user.${field}">
            </patternField>
        </patternFields>
    </mapping>

    <mapping name="PatternFieldTestWithWhen">
        <patternFields>
            <patternField id="when_pattern" fromPattern="data_{field}" to="${field}">
                <when><![CDATA[source[sourceFieldName] != null]]></when>
            </patternField>
        </patternFields>
    </mapping>

    <mapping name="PatternFieldTestWithVirtual">
        <patternFields>
            <patternField id="total_virtual" to="${'total'}">
                <computeExpr>source.amount * source.price</computeExpr>
            </patternField>
        </patternFields>
    </mapping>

    <mapping name="Item_to_Test">
        <fields>
            <field from="c" mandatory="true" name="a">
                <schema/>
            </field>
            <field from="d" mandatory="true" name="b">
                <schema/>
            </field>
        </fields>
    </mapping>

</definitions>
