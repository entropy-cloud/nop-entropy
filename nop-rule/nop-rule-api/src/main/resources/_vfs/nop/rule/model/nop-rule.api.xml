<?xml version="1.0" encoding="UTF-8" ?>
<!--__XGEN_FORCE_OVERRIDE__-->
<api apiPackageName="io.nop.rule.api" ext:appName="nop-rule" ext:serviceModuleName="nop-rule-core"
     ext:servicePackageName="io.nop.rule.core.service" ext:apiModuleName="nop-rule-api"
     ext:mavenGroupId="io.github.entropy-cloud" ext:mavenArtifactId="nop-rule" ext:mavenVersion="2.0.0-SNAPSHOT"
     ext:platformVersion="2.0.0-SNAPSHOT" x:schema="/nop/schema/api.xdef" xmlns:x="/nop/schema/xdsl.xdef"
     xmlns:i18n-en="i18n-en" xmlns:ref-i18n-en="ref-i18n-en" xmlns:ext="ext" xmlns:xpl="xpl" xmlns:ui="ui">

    <messages>
        <message displayName="规则执行请求" name="RuleRequestBean" i18n-en:displayName="Rule Request">
            <field displayName="规则名称" mandatory="true" name="ruleName" propId="1" i18n-en:displayName="Rule Name">
                <schema precision="500" type="String"/>
            </field>
            <field displayName="规则版本" name="ruleVersion" propId="2" i18n-en:displayName="Rule Version">
                <schema type="Long"/>
            </field>
            <field displayName="输入参数" name="inputs" propId="3" i18n-en:displayName="Inputs">
                <schema precision="160000" type="Map&lt;java.lang.String,java.lang.Object&gt;"/>
            </field>
        </message>
        <message displayName="规则执行结果" name="RuleResultBean" i18n-en:displayName="Rule Response">
            <field displayName="规则名称" mandatory="true" name="ruleName" propId="1" i18n-en:displayName="Rule Name">
                <schema precision="500" type="String"/>
            </field>
            <field displayName="规则版本" mandatory="true" name="ruleVersion" propId="2" i18n-en:displayName="Rule Version">
                <schema type="Long"/>
            </field>
            <field displayName="是否匹配" mandatory="true" name="ruleMatch" propId="3" i18n-en:displayName="Rule Match">
                <description>是否匹配了所有业务条件</description>
                <schema type="boolean"/>
            </field>
            <field displayName="输出结果" name="outputs" propId="4" i18n-en:displayName="Outputs">
                <schema precision="160000" type="Map&lt;java.lang.String,java.lang.Object&gt;"/>
            </field>
            <field displayName="日志消息" name="logMessages" propId="5" i18n-en:displayName="Log Messages">
                <schema precision="160000" type="List&lt;io.nop.rule.api.beans.RuleLogMessageBean&gt;"/>
            </field>
        </message>
        <message displayName="日志消息" name="RuleLogMessageBean" i18n-en:displayName="Rule Log Message">
            <field displayName="日志时间" mandatory="true" name="logTime" propId="1" i18n-en:displayName="Log Time">
                <schema type="Timestamp"/>
            </field>
            <field displayName="消息" name="message" propId="2" i18n-en:displayName="Message">
                <schema precision="2000" type="String"/>
            </field>
            <field displayName="规则节点Id" name="ruleNodeId" propId="3" i18n-en:displayName="Rule Node Id">
                <schema precision="200" type="String"/>
            </field>
            <field displayName="规则节点标题" name="ruleNodeLabel" propId="4" i18n-en:displayName="Rule Node Label">
                <schema precision="200" type="String"/>
            </field>
        </message>
        <message displayName="规则唯一标识" name="RuleKeyBean" i18n-en:displayName="Rule Key">
            <field displayName="规则名称" mandatory="true" name="ruleName" propId="1" i18n-en:displayName="Rule Name">
                <schema precision="500" type="String"/>
            </field>
            <field displayName="规则版本" name="ruleVersion" propId="2" i18n-en:displayName="Rule Version">
                <schema type="Long"/>
            </field>
        </message>
        <message displayName="规则元数据" name="RuleMetaBean" i18n-en:displayName="Rule Meta">
            <field displayName="规则名称" mandatory="true" name="ruleName" propId="1" i18n-en:displayName="Rule Name">
                <schema precision="500" type="String"/>
            </field>
            <field displayName="规则版本" name="ruleVersion" propId="2" i18n-en:displayName="Rule Version">
                <schema type="Long"/>
            </field>
            <field displayName="显示名称" name="displayName" propId="3" i18n-en:displayName="Display Name">
                <schema precision="200" type="String"/>
            </field>
            <field displayName="描述" name="description" propId="4" i18n-en:displayName="Description">
                <schema precision="2000" type="String"/>
            </field>
            <field displayName="输入数据类型" name="inputs" propId="5" i18n-en:displayName="Inputs">
                <schema precision="4000" type="List&lt;io.nop.api.core.beans.VarMetaBean&gt;"/>
            </field>
            <field displayName="输出数据类型" name="outputs" propId="6" i18n-en:displayName="Outputs">
                <schema precision="4000" type="List&lt;io.nop.api.core.beans.VarMetaBean&gt;"/>
            </field>
        </message>
    </messages>

    <services>
        <service className="io.nop.rule.api.RuleService" displayName="规则引擎服务" name="RuleService"
                 i18n-en:displayName="Rule Service">
            <method displayName="执行规则" mutation="true" name="executeRule"
                    requestMessage="io.nop.rule.api.beans.RuleRequestBean"
                    responseMessage="io.nop.rule.api.beans.RuleResultBean" tagSet="sync"
                    i18n-en:displayName="Execute Rule"/>
            <method displayName="得到规则元数据" name="getRuleMeta" requestMessage="io.nop.rule.api.beans.RuleKeyBean"
                    responseMessage="io.nop.rule.api.beans.RuleMetaBean" tagSet="sync"
                    i18n-en:displayName="Get Rule Meta"/>
        </service>
    </services>
</api>