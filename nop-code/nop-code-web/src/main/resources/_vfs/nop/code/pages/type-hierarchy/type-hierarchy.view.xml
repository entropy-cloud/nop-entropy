<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:gql="graphql">

    <forms>
        <form id="queryForm" editMode="edit" title="类型层级查询">
            <layout>
 indexId[索引ID]
 qualifiedName[全限定类型名]
 direction[方向]
 maxDepth[最大深度]
            </layout>

            <cells>
                <cell id="indexId" label="索引ID" domain="string"/>
                <cell id="qualifiedName" label="全限定类型名" domain="string"/>
                <cell id="direction" label="方向" domain="string"/>
                <cell id="maxDepth" label="最大深度" domain="int"/>
            </cells>
        </form>
    </forms>

    <pages>
        <simple name="main" form="queryForm">
            <api url="@query:NopCodeTypeHierarchy__getTypeHierarchy?qualifiedName=$qualifiedName&amp;indexId=$indexId&amp;direction=$direction&amp;maxDepth=$maxDepth"/>
        </simple>
    </pages>
</view>
