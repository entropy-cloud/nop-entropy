<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="NopCodeFlow" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/nop/code/model/NopCodeFlow/NopCodeFlow.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--索引ID-->
                <col id="indexId" mandatory="true" sortable="true"/>

                <!--流名称-->
                <col id="name" sortable="true"/>

                <!--入口符号ID-->
                <col id="entryPointId" sortable="true"/>

                <!--入口全限定名-->
                <col id="entryPointQualifiedName" sortable="true"/>

                <!--最大追踪深度-->
                <col id="depth" ui:number="true" sortable="true"/>

                <!--符号总数-->
                <col id="symbolCount" ui:number="true" sortable="true"/>

                <!--文件扩散评分-->
                <col id="fileSpread" ui:number="true" sortable="true"/>

                <!--外部调用评分-->
                <col id="externalScore" ui:number="true" sortable="true"/>

                <!--安全敏感评分-->
                <col id="securityScore" ui:number="true" sortable="true"/>

                <!--测试覆盖缺口评分-->
                <col id="testGap" ui:number="true" sortable="true"/>

                <!--深度复杂度评分-->
                <col id="depthScore" ui:number="true" sortable="true"/>

                <!--综合关键度评分-->
                <col id="overallScore" ui:number="true" sortable="true"/>

                <!--状态-->
                <col id="status" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" sortable="true"/>

                <!--更新时间-->
                <col id="updateTime" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" sortable="true"/>

                <!--更新人-->
                <col id="updatedBy" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-执行流" i18n-en:title="View Execution Flow">
            <layout>
 indexId[索引ID] name[流名称]
 entryPointId[入口符号ID] entryPointQualifiedName[入口全限定名]
 depth[最大追踪深度] symbolCount[符号总数]
 fileSpread[文件扩散评分] externalScore[外部调用评分]
 securityScore[安全敏感评分] testGap[测试覆盖缺口评分]
 depthScore[深度复杂度评分] overallScore[综合关键度评分]
 status[状态] createTime[创建时间]
 updateTime[更新时间] createdBy[创建人]
 updatedBy[更新人] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-执行流" i18n-en:title="Add Execution Flow" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-执行流" i18n-en:title="Edit Execution Flow">
            <layout>
 indexId[索引ID] name[流名称]
 entryPointId[入口符号ID] entryPointQualifiedName[入口全限定名]
 depth[最大追踪深度] symbolCount[符号总数]
 fileSpread[文件扩散评分] externalScore[外部调用评分]
 securityScore[安全敏感评分] testGap[测试覆盖缺口评分]
 depthScore[深度复杂度评分] overallScore[综合关键度评分]
 status[状态] createTime[创建时间]
 updateTime[更新时间] createdBy[创建人]
 updatedBy[更新人] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-执行流" i18n-en:title="Update Execution Flow"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopCodeFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:NopCodeFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:NopCodeFlow__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:NopCodeFlow__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:NopCodeFlow__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:NopCodeFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:NopCodeFlow__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:NopCodeFlow__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:NopCodeFlow__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:NopCodeFlow__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>