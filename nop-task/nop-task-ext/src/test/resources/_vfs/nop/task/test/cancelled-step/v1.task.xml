<task x:schema="/nop/schema/task/task.xdef" xmlns:x="/nop/schema/xdsl.xdef">
    <steps>
        <xpl name="cancelledStep">
            <source><![CDATA[
                const sim = inject("testFailureSimulator");
                sim.throwCancelled();
            ]]></source>
            <output name="RESULT"/>
        </xpl>
    </steps>

    <output name="RESULT">
        <source>
            return RESULT
        </source>
    </output>
</task>
