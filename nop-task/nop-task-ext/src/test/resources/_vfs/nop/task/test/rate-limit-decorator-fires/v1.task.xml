<task x:schema="/nop/schema/task/task.xdef" xmlns:x="/nop/schema/xdsl.xdef">
    <steps>
        <xpl name="rateLimitedStep">
            <decorator name="rateLimit" rateLimit:requestPerSecond="0.0001" rateLimit:global="true" rateLimit:maxWait="0"/>
            <source><![CDATA[
                const counter = inject("testExecutionCounter");
                counter.incrementAndGet();
                return "OK";
            ]]></source>
            <output name="RESULT"/>
        </xpl>
    </steps>

    <output name="RESULT">
        <source>
            return RESULT
        </source>
    </output>
</task>
