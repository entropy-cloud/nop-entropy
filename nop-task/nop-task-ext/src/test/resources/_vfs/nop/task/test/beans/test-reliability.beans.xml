<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ioc="ioc">
    <bean id="testExecutionCounter" class="io.nop.task.ext.reliability.ExecutionCounterBean"/>
    <bean id="testFailureSimulator" class="io.nop.task.ext.reliability.FailureSimulatorBean">
        <property name="counter" ref="testExecutionCounter"/>
    </bean>

    <!-- Plan 253: async + fail-then-succeed helper for succeed-driver E2E -->
    <bean id="testStepStateHelper" class="io.nop.task.ext.reliability.StepStateTestHelper">
        <property name="counter" ref="testExecutionCounter"/>
    </bean>

    <!-- Plan 252: state-capturing store for E2E step-state assertions -->
    <bean id="testStateCapturingStore" class="io.nop.task.ext.reliability.StateCapturingTaskStateStore"/>

    <!-- Override nopTaskFlowManager to use state-capturing non-persist store (behavior identical to DefaultTaskStateStore) -->
    <bean id="nopTaskFlowManager" class="io.nop.task.impl.TaskFlowManagerImpl" ioc:allow-override="true">
        <property name="nonPersistStateStore" ref="testStateCapturingStore"/>
    </bean>
</beans>
