<task x:schema="/nop/schema/task/task.xdef" xmlns:x="/nop/schema/xdsl.xdef">
    <steps>
        <xpl name="slowStep">
            <decorator name="timeout" timeout:timeout="200"/>
            <source><![CDATA[
                const counter = inject("testExecutionCounter");
                counter.incrementAndGet();
                java.lang.Thread.sleep(2000);
                return "completed-but-too-late";
            ]]></source>
            <output name="RESULT"/>
        </xpl>
    </steps>

    <output name="RESULT">
        <source>
            return RESULT
        </source>
    </output>
</task>
