<task x:schema="/nop/schema/task/task.xdef" xmlns:x="/nop/schema/xdsl.xdef">
    <steps>
        <selector name="selFailStep">
            <steps>
                <xpl name="s1">
                    <source>return false</source>
                </xpl>
                <xpl name="innerFail">
                    <source><![CDATA[
                        const sim = inject("testFailureSimulator");
                        sim.throwRecoverable();
                    ]]></source>
                </xpl>
            </steps>
        </selector>
    </steps>

    <output name="RESULT">
        <source>
            return RESULT
        </source>
    </output>
</task>
