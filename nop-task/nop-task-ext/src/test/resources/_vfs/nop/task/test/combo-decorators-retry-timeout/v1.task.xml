<task x:schema="/nop/schema/task/task.xdef" xmlns:x="/nop/schema/xdsl.xdef">
    <steps>
        <xpl name="comboStep">
            <decorator name="retry" retry:maxRetryCount="2" retry:retryDelay="0"/>
            <decorator name="timeout" timeout:timeout="5000"/>
            <source><![CDATA[
                import io.nop.api.core.exceptions.NopException;
                const counter = inject("testExecutionCounter");
                counter.incrementAndGet();
                throw new NopException("nop.err.test.combo-transient");
            ]]></source>
            <output name="RESULT"/>
        </xpl>
    </steps>

    <output name="RESULT">
        <source>
            return RESULT
        </source>
    </output>
</task>
