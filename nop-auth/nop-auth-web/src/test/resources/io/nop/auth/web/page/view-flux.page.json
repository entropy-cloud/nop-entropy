      {
        "type": "flex",
        "id": "row-long",
        "body": {
          "name": "long",
          "label": "longLabel",
          "hiddenFieldPolicy": {
            "clearValueWhenHidden": false
          },
          "type": "text"
        }
      },
      {
        "type": "flex",
        "id": "row-email",
        "body": {
          "name": "email",
          "label": "emailLabel",
          "hiddenFieldPolicy": {
            "clearValueWhenHidden": false
          },
