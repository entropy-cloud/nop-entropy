<?xml version="1.0" encoding="UTF-8" ?>

<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd" xmlns:ioc="ioc">

    <bean id="nopGatewayHttpFilter" class="io.nop.gateway.http.GatewayHttpFilter"
          ioc:default="true">
        <ioc:condition>
            <if-property name="nop.gateway.http-filter.enabled" />
        </ioc:condition>

        <property name="executionInvoker" ref="nopSingleSessionFunctionInvoker" />
    </bean>

    <bean id="nopGatewayLogger" class="io.nop.gateway.core.interceptor.Slf4jGatewayLogger"
          ioc:default="true">
        <ioc:condition>
            <if-property name="nop.gateway.logging.enabled" />
        </ioc:condition>
    </bean>

    <bean id="nopLoggingGatewayInterceptor" class="io.nop.gateway.core.interceptor.LoggingInterceptor"
          ioc:default="true">
        <ioc:condition>
            <if-property name="nop.gateway.logging.enabled" />
        </ioc:condition>
        <constructor-arg index="0" ref="nopGatewayLogger"/>
    </bean>

    <!-- AI Backend Message Converters — 命名约定 nopBackendMessageConverter_{AiBackendType}，
         由 AiBackendMessageConverter.getConverter() 按 bean 名查找。
         DeepSeek/Gemini 在本模块提供；OpenAI/Claude/Ollama 等方言式转换由 nop-ai-gateway 模块的
         AiDialectBackendMessageConverter 注册。 -->
    <bean id="nopBackendMessageConverter_DEEPSEEK"
          class="io.nop.gateway.conversion.ai.DeepSeekMessageConverter"
          ioc:type="io.nop.gateway.conversion.IBackendMessageConverter"
          ioc:default="true" />

    <bean id="nopBackendMessageConverter_GEMINI"
          class="io.nop.gateway.conversion.ai.GeminiMessageConverter"
          ioc:type="io.nop.gateway.conversion.IBackendMessageConverter"
          ioc:default="true" />

    <!-- AI Gateway 拦截器 -->
    <bean id="nopAiAuthGatewayInterceptor"
          class="io.nop.gateway.core.interceptor.AiAuthGatewayInterceptor"
          ioc:default="true">
        <property name="validKeys">
            <list>
                <value>sk-test-key-1</value>
                <value>sk-test-key-2</value>
            </list>
        </property>
    </bean>

    <bean id="nopAiRateLimitGatewayInterceptor"
          class="io.nop.gateway.core.interceptor.AiRateLimitGatewayInterceptor"
          ioc:default="true">
        <property name="capacity" value="10" />
        <property name="refillRate" value="1" />
        <property name="refillIntervalMs" value="1000" />
    </bean>

    <bean id="nopAiFailoverGatewayInterceptor"
          class="io.nop.gateway.core.interceptor.AiFailoverGatewayInterceptor"
          ioc:default="true">
        <property name="fallbackUrls">
            <list />
        </property>
        <property name="maxRetries" value="3" />
    </bean>

</beans>
