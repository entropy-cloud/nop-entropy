<?xml version="1.0" encoding="UTF-8" ?>
<workflow x:schema="/nop/schema/wf/wf.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <start startStepName="wf-start"/>

    <end/>

    <steps>
        <step displayName="启动" name="wf-start">
            <assignment ignoreNoAssign="true">
                <actors>
                    <actor actorId="1" actorType="user" actorModelId="actor1"/>
                </actors>
            </assignment>
            <ref-actions>
                <ref-action name="sh"/>
            </ref-actions>
        </step>
        <step displayName="串签" name="review" execGroupType="seq-group">
            <assignment selection="auto">
                <actors>
                    <actor actorId="1" actorType="user" actorModelId="actor1"/>
                    <actor actorId="2" actorType="user" actorModelId="actor2"/>
                    <actor actorId="3" actorType="user" actorModelId="actor3"/>
                </actors>
            </assignment>
            <ref-actions>
                <ref-action name="sp"/>
            </ref-actions>
        </step>
    </steps>

    <actions>
        <action displayName="审核" name="sh">
            <transition>
                <to-step stepName="review"/>
            </transition>
        </action>
        <action displayName="审批" name="sp">
            <transition>
                <to-end/>
            </transition>
        </action>
    </actions>
</workflow>
