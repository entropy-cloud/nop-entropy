<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="/nop/job/beans/app-local-scheduler.beans.xml"/>

    <bean id="wfTaskScanner" class="io.nop.wf.scheduler.WfTaskScanner">
        <property name="reminderListeners">
            <ioc:collect-beans by-type="io.nop.wf.scheduler.IWfTaskReminderListener"/>
        </property>
    </bean>
</beans>
